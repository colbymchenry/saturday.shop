{% comment %}
  Injects school name + color badges into Slidecart line items.
  Outputs a school lookup map as JSON, then uses a MutationObserver
  to decorate each Slidecart line item when it appears.
{% endcomment %}

<script data-slidecart-schools type="application/json">
  {%- paginate shop.metaobjects.school.values by 250 -%}
    {
      {%- for school in shop.metaobjects.school.values -%}
        {{ school.slug | json }}: {
          "name": {{ school.name | json }},
          "color": "{{ school.primary_color }}"
        }{%- unless forloop.last -%},{%- endunless -%}
      {%- endfor -%}
    }
  {%- endpaginate -%}
</script>

<style>
  #slidecarthq .slidecart-school-badge {
    display: block;
    font-family: var(--font-heading--family, sans-serif);
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-top: 4px;
    line-height: 1.3;
  }
</style>

<script>
  (function() {
    var schoolMap;
    try {
      schoolMap = JSON.parse(
        document.querySelector('script[data-slidecart-schools]').textContent
      );
    } catch (e) { return; }

    var productCache = {};

    function getProductHandle(url) {
      if (!url) return null;
      var match = url.match(/\/products\/([^?#/]+)/);
      return match ? match[1] : null;
    }

    function fetchProduct(handle) {
      if (productCache[handle]) return productCache[handle];
      productCache[handle] = fetch('/products/' + handle + '.js')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          productCache[handle] = Promise.resolve(data);
          return data;
        })
        .catch(function() {
          delete productCache[handle];
          return null;
        });
      return productCache[handle];
    }

    function decorateItem(itemEl) {
      if (itemEl.querySelector('.slidecart-school-badge')) return;

      var anchor = itemEl.querySelector('a.item-image-anchor, a[href*="/products/"]');
      if (!anchor) return;

      var handle = getProductHandle(anchor.getAttribute('href'));
      if (!handle) return;

      fetchProduct(handle).then(function(product) {
        if (!product || !product.tags) return;
        if (itemEl.querySelector('.slidecart-school-badge')) return;

        var school = null;
        for (var i = 0; i < product.tags.length; i++) {
          var tag = product.tags[i].toLowerCase().replace(/\s+/g, '-');
          if (schoolMap[tag]) {
            school = schoolMap[tag];
            break;
          }
        }

        if (!school) {
          var h = '-' + product.handle + '-';
          var slugs = Object.keys(schoolMap).sort(function(a, b) { return b.length - a.length; });
          for (var k = 0; k < slugs.length; k++) {
            if (h.indexOf('-' + slugs[k] + '-') !== -1) {
              school = schoolMap[slugs[k]];
              break;
            }
          }
        }

        if (!school) return;

        var badge = document.createElement('span');
        badge.className = 'slidecart-school-badge';
        badge.textContent = school.name;
        badge.style.color = school.color;

        var properties = itemEl.querySelector('.properties-key-value');
        var titleEl = itemEl.querySelector('.title');
        var anchor = properties || titleEl;
        if (anchor) {
          anchor.parentNode.insertBefore(badge, anchor.nextSibling);
        }
      });
    }

    function decorateAll() {
      var items = document.querySelectorAll('#slidecarthq .item');
      items.forEach(decorateItem);
    }

    var slidecart = document.getElementById('slidecarthq');
    if (!slidecart) {
      var waitForSlidecart = setInterval(function() {
        slidecart = document.getElementById('slidecarthq');
        if (slidecart) {
          clearInterval(waitForSlidecart);
          observe(slidecart);
        }
      }, 500);
    } else {
      observe(slidecart);
    }

    function observe(root) {
      decorateAll();
      new MutationObserver(function(mutations) {
        var shouldDecorate = false;
        for (var i = 0; i < mutations.length; i++) {
          if (mutations[i].addedNodes.length > 0) {
            shouldDecorate = true;
            break;
          }
        }
        if (shouldDecorate) decorateAll();
      }).observe(root, { childList: true, subtree: true });
    }
  })();
</script>
