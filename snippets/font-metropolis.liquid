{% comment %}
  Self-hosted Metropolis @font-face declarations.
  Metropolis is an open-source geometric sans-serif (Proxima Nova alternative).
  https://github.com/dw5/Metropolis

  .woff2 files in assets/:
    Metropolis-Thin.woff2            (100)
    Metropolis-Light.woff2           (300)
    Metropolis-Regular.woff2         (400)
    Metropolis-RegularItalic.woff2   (400 italic)
    Metropolis-Medium.woff2          (500)
    Metropolis-SemiBold.woff2        (600)
    Metropolis-Bold.woff2            (700)
    Metropolis-ExtraBold.woff2       (800)
    Metropolis-Black.woff2           (900)
{% endcomment %}

{% style %}
  @font-face {
    font-family: 'Metropolis';
    font-weight: 100;
    font-style: normal;
    font-display: swap;
    src: url({{ 'Metropolis-Thin.woff2' | asset_url }}) format('woff2');
  }

  @font-face {
    font-family: 'Metropolis';
    font-weight: 300;
    font-style: normal;
    font-display: swap;
    src: url({{ 'Metropolis-Light.woff2' | asset_url }}) format('woff2');
  }

  @font-face {
    font-family: 'Metropolis';
    font-weight: 400;
    font-style: normal;
    font-display: swap;
    src: url({{ 'Metropolis-Regular.woff2' | asset_url }}) format('woff2');
  }

  @font-face {
    font-family: 'Metropolis';
    font-weight: 400;
    font-style: italic;
    font-display: swap;
    src: url({{ 'Metropolis-RegularItalic.woff2' | asset_url }}) format('woff2');
  }

  @font-face {
    font-family: 'Metropolis';
    font-weight: 500;
    font-style: normal;
    font-display: swap;
    src: url({{ 'Metropolis-Medium.woff2' | asset_url }}) format('woff2');
  }

  @font-face {
    font-family: 'Metropolis';
    font-weight: 600;
    font-style: normal;
    font-display: swap;
    src: url({{ 'Metropolis-SemiBold.woff2' | asset_url }}) format('woff2');
  }

  @font-face {
    font-family: 'Metropolis';
    font-weight: 700;
    font-style: normal;
    font-display: swap;
    src: url({{ 'Metropolis-Bold.woff2' | asset_url }}) format('woff2');
  }

  @font-face {
    font-family: 'Metropolis';
    font-weight: 800;
    font-style: normal;
    font-display: swap;
    src: url({{ 'Metropolis-ExtraBold.woff2' | asset_url }}) format('woff2');
  }

  @font-face {
    font-family: 'Metropolis';
    font-weight: 900;
    font-style: normal;
    font-display: swap;
    src: url({{ 'Metropolis-Black.woff2' | asset_url }}) format('woff2');
  }
{% endstyle %}
