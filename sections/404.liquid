{% comment %}
  This section is used in the 404 template to render page shown when customers
  enter an invalid store URL.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/404
{% endcomment %}

<div class="not-found full-width">
  <div class="not-found__stripes"></div>
  <div class="not-found__watermark" aria-hidden="true">404</div>
  <div class="not-found__content">
    <div class="not-found__rule">
      <span class="not-found__rule-line"></span>
      <span class="not-found__rule-diamond"></span>
      <span class="not-found__rule-line"></span>
    </div>
    <h1 class="not-found__code">404</h1>
    <p class="not-found__message">{{ '404.not_found' | t }}</p>
    <p class="not-found__sub">The page you're looking for has been moved, removed, or never existed.</p>
    <a href="{{ routes.all_products_collection_url }}" class="not-found__cta">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
      {{ '404.back_to_shopping' | t }}
    </a>
  </div>
</div>

<div class="coming-soon full-width" hidden>
  <div class="coming-soon__stripes"></div>
  <div class="coming-soon__content">
    <div class="coming-soon__logo-ring">
      <div class="coming-soon__logo-slot"></div>
    </div>
    <div class="coming-soon__rule">
      <span class="coming-soon__rule-line"></span>
      <span class="coming-soon__rule-diamond"></span>
      <span class="coming-soon__rule-line"></span>
    </div>
    <h2 class="coming-soon__title">Coming Soon</h2>
    <p class="coming-soon__slogan" hidden></p>
    <p class="coming-soon__school-name"></p>
    <p class="coming-soon__text"></p>
    <a href="/pages/contact" class="coming-soon__cta">Get Notified</a>
  </div>
  <div class="coming-soon__watermark" aria-hidden="true">Saturday</div>
</div>

<script>
  (function() {
    var match = window.location.pathname.match(/^\/collections\/([^\/]+)/);
    if (!match) return;
    var slug = match[1];
    var schools = {
      {%- paginate shop.metaobjects.school.values by 250 -%}
        {%- for school in shop.metaobjects.school.values -%}
          {{ school.slug | json }}: {
            logo: {{ school.logo | image_url: width: 300 | json }},
            name: {{ school.name | json }},
            color: "{{ school.primary_color }}",
            slogan: {{ school.slogan | json }}
          }{% unless forloop.last %},{% endunless %}
        {%- endfor -%}
      {%- endpaginate -%}
    };
    if (!(slug in schools)) return;
    var s = schools[slug];
    document.title = s.name + ' \u2013 Coming Soon \u2013 {{ shop.name | escape }}';
    document.querySelector('.not-found').hidden = true;
    var el = document.querySelector('.coming-soon');
    if (s.color) el.style.setProperty('--school-primary', s.color);
    el.querySelector('.coming-soon__school-name').textContent = s.name + ' Collection';
    el.querySelector('.coming-soon__text').textContent = "We\u2019re crafting something special for " + s.name + " nation. Stay tuned.";
    if (s.slogan) {
      var sloganEl = el.querySelector('.coming-soon__slogan');
      sloganEl.textContent = s.slogan;
      sloganEl.hidden = false;
      el.querySelector('.coming-soon__watermark').textContent = s.slogan;
    }
    if (s.logo) {
      var img = document.createElement('img');
      img.src = s.logo;
      img.alt = '';
      img.width = 300;
      img.height = 300;
      img.className = 'coming-soon__logo';
      el.querySelector('.coming-soon__logo-slot').appendChild(img);
    }
    el.hidden = false;
  })();
</script>

{% stylesheet %}
  /* ───── Default 404 page ───── */
  main:has(.not-found) {
    display: flex;
    flex-direction: column;
  }

  main:has(.not-found) > .shopify-section {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .not-found {
    position: relative;
    overflow: hidden;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 6rem 2rem;
    background: var(--color-foreground);
    color: var(--color-background);
  }

  .not-found[hidden] {
    display: none;
  }

  .not-found__stripes {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 28px,
      var(--color-background) 28px,
      var(--color-background) 30px
    );
    opacity: 0.03;
    pointer-events: none;
  }

  .not-found__watermark {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-heading--family);
    font-size: clamp(14rem, 35vw, 28rem);
    font-weight: 800;
    font-style: italic;
    color: var(--color-background);
    opacity: 0.04;
    line-height: 1;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
  }

  .not-found__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
  }

  .not-found__rule {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    width: 80px;
    margin-bottom: 0.5rem;
    animation: not-found-rise 0.5s ease-out both;
  }

  .not-found__rule-line {
    flex: 1;
    height: 2px;
    background: var(--color-background);
    opacity: 0.25;
  }

  .not-found__rule-diamond {
    width: 6px;
    height: 6px;
    background: var(--color-background);
    transform: rotate(45deg);
    opacity: 0.3;
    flex-shrink: 0;
  }

  .not-found__code {
    font-family: var(--font-heading--family);
    font-size: clamp(4rem, 12vw, 8rem);
    font-weight: 800;
    font-style: italic;
    text-transform: uppercase;
    letter-spacing: -0.03em;
    line-height: 1;
    margin: 0;
    animation: not-found-rise 0.5s ease-out 0.08s both;
  }

  .not-found__message {
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    opacity: 0.5;
    margin: 0;
    animation: not-found-rise 0.5s ease-out 0.16s both;
  }

  .not-found__sub {
    font-family: var(--font-body--family);
    font-size: 0.95rem;
    line-height: 1.6;
    opacity: 0.4;
    max-width: 360px;
    margin: 0;
    animation: not-found-rise 0.5s ease-out 0.24s both;
  }

  .not-found__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 1rem;
    padding: 14px 32px;
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-foreground);
    background: var(--color-background);
    transition: opacity 0.2s ease, transform 0.2s ease;
    animation: not-found-rise 0.5s ease-out 0.35s both;
  }

  .not-found__cta:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  @keyframes not-found-rise {
    0% { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  @media (max-width: 768px) {
    .not-found {
      padding: 4rem 1.5rem;
    }

    .not-found__watermark {
      font-size: clamp(10rem, 30vw, 18rem);
    }
  }

  /* ───── Coming Soon (school 404) ───── */
  main:has(.coming-soon:not([hidden])) {
    display: flex;
    flex-direction: column;
  }

  main:has(.coming-soon:not([hidden])) > .shopify-section {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .coming-soon[hidden] {
    display: none;
  }

  .coming-soon {
    position: relative;
    overflow: hidden;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5rem 2rem;
    border-top: 4px solid var(--school-primary, var(--color-foreground));
    border-bottom: 4px solid var(--school-primary, var(--color-foreground));
    background: var(--color-background);
  }

  .coming-soon__stripes {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      -45deg,
      transparent,
      transparent 28px,
      var(--school-primary, var(--color-foreground)) 28px,
      var(--school-primary, var(--color-foreground)) 30px
    );
    opacity: 0.05;
    pointer-events: none;
  }

  .coming-soon__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1.25rem;
  }

  .coming-soon__logo-ring {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    border: 3px solid var(--school-primary, var(--color-foreground));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 22px;
    background: var(--color-background);
    box-shadow: 0 0 0 8px color-mix(in srgb, var(--school-primary, var(--color-foreground)) 8%, transparent);
    animation: coming-soon-pop 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) both;
  }

  .coming-soon__logo {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .coming-soon__rule {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    width: 160px;
    animation: coming-soon-rise 0.5s ease-out 0.1s both;
  }

  .coming-soon__rule-line {
    flex: 1;
    height: 2px;
    background: var(--school-primary, var(--color-foreground));
    opacity: 0.25;
  }

  .coming-soon__rule-diamond {
    width: 7px;
    height: 7px;
    background: var(--school-primary, var(--color-foreground));
    transform: rotate(45deg);
    opacity: 0.3;
    flex-shrink: 0;
  }

  .coming-soon__title {
    font-family: var(--font-heading--family);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    font-style: italic;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 1;
    margin: 0;
    animation: coming-soon-rise 0.5s ease-out 0.2s both;
  }

  .coming-soon__slogan {
    font-family: var(--font-heading--family);
    font-size: clamp(1rem, 3vw, 1.5rem);
    font-weight: 800;
    font-style: italic;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--school-primary, var(--color-foreground));
    margin: 0;
    animation: coming-soon-rise 0.5s ease-out 0.25s both;
  }

  .coming-soon__school-name {
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--school-primary, var(--color-foreground));
    margin: 0;
    animation: coming-soon-rise 0.5s ease-out 0.3s both;
  }

  .coming-soon__text {
    font-family: var(--font-body--family);
    font-size: 1rem;
    color: var(--color-foreground);
    opacity: 0.55;
    margin: 0;
    max-width: 380px;
    line-height: 1.6;
    animation: coming-soon-rise 0.5s ease-out 0.35s both;
  }

  .coming-soon__cta {
    display: inline-block;
    background: var(--school-primary, var(--color-foreground));
    color: white;
    font-family: var(--font-heading--family);
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    text-decoration: none;
    padding: 0.85rem 2.5rem;
    margin-top: 0.5rem;
    transition: opacity 0.2s ease, transform 0.2s ease;
    animation: coming-soon-rise 0.5s ease-out 0.45s both;
  }

  .coming-soon__cta:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }

  .coming-soon__watermark {
    position: absolute;
    bottom: -0.8rem;
    right: -0.5rem;
    font-family: var(--font-heading--family);
    font-size: clamp(6rem, 18vw, 14rem);
    font-weight: 800;
    font-style: italic;
    text-transform: uppercase;
    color: var(--school-primary, var(--color-foreground));
    opacity: 0.035;
    line-height: 1;
    white-space: nowrap;
    pointer-events: none;
    user-select: none;
  }

  @keyframes coming-soon-pop {
    0% { opacity: 0; transform: scale(0.7); }
    100% { opacity: 1; transform: scale(1); }
  }

  @keyframes coming-soon-rise {
    0% { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.404",
  "settings": []
}
{% endschema %}
