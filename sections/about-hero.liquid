<section class="about-hero full-width" style="background-color: {{ section.settings.background_color }};">
  <div class="about-hero__inner">
    <div class="about-hero__content">
      {% if section.settings.eyebrow != blank %}
        <p class="about-hero__eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}

      {% if section.settings.heading_bold != blank or section.settings.heading_script != blank %}
        <h1 class="about-hero__heading">
          {%- if section.settings.heading_bold != blank -%}
            <span class="about-hero__heading-bold">{{ section.settings.heading_bold }}</span>
          {%- endif %} {%- if section.settings.heading_script != blank -%}
            <span class="about-hero__heading-script">{{ section.settings.heading_script }}</span>
          {%- endif -%}
        </h1>
      {% endif %}

      {% if section.settings.body != blank %}
        <p class="about-hero__body">{{ section.settings.body }}</p>
      {% endif %}

      {% if section.settings.button_text != blank %}
        <a href="{{ section.settings.button_url }}" class="about-hero__button">
          {{ section.settings.button_text }}
        </a>
      {% endif %}
    </div>

    <div class="about-hero__media">
      {% if section.settings.image %}
        {{ section.settings.image | image_url: width: 1400 | image_tag: loading: 'eager' }}
      {% else %}
        {{ 'hero-apparel-1' | placeholder_svg_tag }}
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .about-hero {
    overflow: hidden;
  }

  .about-hero__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 80vh;
  }

  .about-hero__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 80px clamp(32px, 5vw, 64px);
    margin-left: auto;
    max-width: 580px;
  }

  .about-hero__eyebrow {
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent-gold);
    margin-bottom: 28px;
    position: relative;
    padding-left: 48px;
  }

  .about-hero__eyebrow::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    width: 32px;
    height: 1px;
    background-color: var(--color-accent-gold);
  }

  .about-hero__heading {
    font-size: clamp(2.5rem, 5.5vw, 4.2rem);
    line-height: 1.05;
    margin: 0;
  }

  .about-hero__heading-bold {
    font-family: var(--font-heading--family);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: var(--color-foreground);
  }

  .about-hero__heading-script {
    display: block;
    font-family: var(--font-heading--family);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.01em;
    color: var(--color-accent-rust);
    font-size: 0.6em;
    margin-top: 8px;
  }

  .about-hero__body {
    font-family: var(--font-body--family);
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
    line-height: 1.7;
    color: var(--color-muted);
    margin-top: 28px;
    max-width: 480px;
  }

  .about-hero__button {
    display: inline-block;
    margin-top: 36px;
    padding: 16px 40px;
    font-family: var(--font-heading--family);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-background);
    background-color: var(--color-foreground);
    transition: opacity 0.2s ease;
    align-self: flex-start;
  }

  .about-hero__button:hover {
    opacity: 0.85;
  }

  .about-hero__media {
    position: relative;
    overflow: hidden;
  }

  .about-hero__media img,
  .about-hero__media svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @media (max-width: 900px) {
    .about-hero__inner {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .about-hero__media {
      order: -1;
      aspect-ratio: 4 / 3;
    }

    .about-hero__content {
      max-width: none;
      margin-left: 0;
      padding: 48px clamp(20px, 5vw, 48px);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.about_hero",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#F5F2EB"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "OUR STORY"
    },
    {
      "type": "text",
      "id": "heading_bold",
      "label": "t:labels.heading_bold",
      "default": "YOUR SCHOOL DESERVES"
    },
    {
      "type": "text",
      "id": "heading_script",
      "label": "t:labels.heading_script",
      "default": "more than a template."
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "t:labels.description",
      "default": "Saturday Co was born from a simple belief: college apparel should celebrate what makes each school truly unique — the traditions, landmarks, and inside jokes that only students and alumni would know."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:labels.button_text"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:labels.button_url"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    }
  ],
  "presets": [
    {
      "name": "t:general.about_hero"
    }
  ]
}
{% endschema %}
