<section class="conference-nav full-width" style="background-color: {{ section.settings.background_color }};">
  {% if section.settings.heading != blank %}
    <h2 class="conference-nav__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  {% assign live_conferences = '' %}
  {% for school in shop.metaobjects.school.values %}
    {% assign school_conf = school.conference.value %}
    {% if school_conf %}
      {% assign school_col = collections[school.slug] %}
      {% if school_col != blank and school_col.all_products_count > 0 %}
        {% assign conf_handle = school_conf.system.handle %}
        {% assign delimited_list = ',' | append: live_conferences | append: ',' %}
        {% assign delimited_handle = ',' | append: conf_handle | append: ',' %}
        {% unless delimited_list contains delimited_handle %}
          {% if live_conferences != '' %}
            {% assign live_conferences = live_conferences | append: ',' %}
          {% endif %}
          {% assign live_conferences = live_conferences | append: conf_handle %}
        {% endunless %}
      {% endif %}
    {% endif %}
  {% endfor %}

  <div class="conference-nav__list">
    {% assign conference_order = 'sec,acc,mountain-west,big-ten,big-12,american,socon,big-east,pac-12,mid-american,sun-belt,a-10,c-usa,missouri-valley' | split: ',' %}
    {% for handle in conference_order %}
      {% assign conference = shop.metaobjects.conference[handle] %}
      {% if conference %}
        {% assign delimited_list = ',' | append: live_conferences | append: ',' %}
        {% assign delimited_handle = ',' | append: handle | append: ',' %}
        {% assign has_schools = false %}
        {% if delimited_list contains delimited_handle %}
          {% assign has_schools = true %}
        {% endif %}

        <a href="/pages/schools#conference={{ conference.name.value | url_encode | replace: '+', '%20' }}" class="conference-nav__item{% unless has_schools %} conference-nav__item--coming-soon{% endunless %}">
          <div class="conference-nav__circle">
            {% if conference.logo.value %}
              {{ conference.logo.value | image_url: width: 128 | image_tag: loading: 'lazy' }}
            {% else %}
              <span>{{ conference.abbreviation.value }}</span>
            {% endif %}
            {% unless has_schools %}
              <span class="conference-nav__coming-soon">COMING<br>SOON</span>
            {% endunless %}
          </div>
          <span class="conference-nav__name">{{ conference.name.value }}</span>
        </a>
      {% endif %}
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .conference-nav {
    padding: 40px var(--page-margin);
    text-align: center;
  }

  .conference-nav__heading {
    font-family: var(--font-heading--family);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-foreground);
    margin-bottom: 28px;
  }

  .conference-nav__list {
    display: flex;
    justify-content: center;
    gap: 20px;
    overflow-x: auto;
    scrollbar-width: none;
    padding: 8px var(--page-margin);
    -webkit-overflow-scrolling: touch;
  }

  .conference-nav__list::-webkit-scrollbar {
    display: none;
  }

  .conference-nav__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .conference-nav__circle {
    position: relative;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background-color: var(--color-cream);
    color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading--family);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    overflow: hidden;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .conference-nav__circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .conference-nav__item--coming-soon {
    pointer-events: none;
  }

  .conference-nav__item--coming-soon .conference-nav__circle img,
  .conference-nav__item--coming-soon .conference-nav__circle > span:not(.conference-nav__coming-soon) {
    opacity: 0.15;
  }

  .conference-nav__coming-soon {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading--family);
    font-size: 0.45rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.3;
    text-align: center;
    color: var(--color-foreground);
  }

  .conference-nav__item:hover .conference-nav__circle {
    transform: scale(1.08);
    opacity: 0.85;
  }

  .conference-nav__name {
    font-family: var(--font-body--family);
    font-size: 0.7rem;
    color: var(--color-muted);
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .conference-nav__list {
      justify-content: flex-start;
    }

    .conference-nav__circle {
      width: 52px;
      height: 52px;
      font-size: 0.7rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.conference_nav",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "SHOP BY CONFERENCE"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "t:general.conference_nav"
    }
  ]
}
{% endschema %}
