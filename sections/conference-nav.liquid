<section class="conference-nav full-width" style="background-color: {{ section.settings.background_color }};">
  {% if section.settings.heading != blank %}
    <h2 class="conference-nav__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="conference-nav__list">
    {% for conference in shop.metaobjects.conference.values %}
      <a href="/pages/schools#conference={{ conference.name.value | url_encode }}" class="conference-nav__item">
        <div class="conference-nav__circle">
          {% if conference.logo.value %}
            {{ conference.logo.value | image_url: width: 128 | image_tag: loading: 'lazy' }}
          {% else %}
            <span>{{ conference.abbreviation.value }}</span>
          {% endif %}
        </div>
        <span class="conference-nav__name">{{ conference.name.value }}</span>
      </a>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .conference-nav {
    padding: 40px var(--page-margin);
    text-align: center;
  }

  .conference-nav__heading {
    font-family: var(--font-heading--family);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-foreground);
    margin-bottom: 28px;
  }

  .conference-nav__list {
    display: flex;
    justify-content: center;
    gap: 20px;
    overflow-x: auto;
    scrollbar-width: none;
    padding: 0 var(--page-margin);
    -webkit-overflow-scrolling: touch;
  }

  .conference-nav__list::-webkit-scrollbar {
    display: none;
  }

  .conference-nav__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .conference-nav__circle {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background-color: var(--color-foreground);
    color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading--family);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    overflow: hidden;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .conference-nav__circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .conference-nav__item:hover .conference-nav__circle {
    transform: scale(1.08);
    opacity: 0.85;
  }

  .conference-nav__name {
    font-family: var(--font-body--family);
    font-size: 0.7rem;
    color: var(--color-muted);
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .conference-nav__list {
      justify-content: flex-start;
    }

    .conference-nav__circle {
      width: 52px;
      height: 52px;
      font-size: 0.7rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.conference_nav",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "SHOP BY CONFERENCE"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "t:general.conference_nav"
    }
  ]
}
{% endschema %}
