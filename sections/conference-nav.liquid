<section class="conference-nav full-width" style="background-color: {{ section.settings.background_color }};">
  {% if section.settings.heading != blank %}
    <h2 class="conference-nav__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  {% comment %} Single pass: record each school's conference and live status {% endcomment %}
  {% assign school_conf_data = '' %}
  {% paginate shop.metaobjects.school.values by 250 %}
  {% for school in shop.metaobjects.school.values %}
    {% assign school_conf = school.conference.value %}
    {% if school_conf %}
      {% assign conf_handle = school_conf.system.handle %}
      {% assign school_col = collections[school.slug] %}
      {% assign is_live = '0' %}
      {% if school_col != blank and school_col.all_products_count > 0 %}
        {% assign is_live = '1' %}
      {% endif %}
      {% if school_conf_data != '' %}{% assign school_conf_data = school_conf_data | append: ',' %}{% endif %}
      {% assign school_conf_data = school_conf_data | append: conf_handle | append: ':' | append: is_live %}
    {% endif %}
  {% endfor %}
  {% endpaginate %}
  {% assign school_entries = school_conf_data | split: ',' %}

  {% comment %} Per conference: count live and total schools, build sortable entries {% endcomment %}
  {% assign conference_handles = 'sec,acc,mountain-west,big-ten,big-12,american,socon,big-east,pac-12,mid-american,sun-belt,a-10,c-usa,missouri-valley' | split: ',' %}
  {% assign active_entries = '' %}
  {% assign soon_entries = '' %}

  {% for handle in conference_handles %}
    {% assign conference = shop.metaobjects.conference[handle] %}
    {% unless conference %}{% continue %}{% endunless %}

    {% assign live_count = 0 %}
    {% assign total_count = 0 %}
    {% for entry in school_entries %}
      {% assign parts = entry | split: ':' %}
      {% if parts[0] == handle %}
        {% assign total_count = total_count | plus: 1 %}
        {% if parts[1] == '1' %}
          {% assign live_count = live_count | plus: 1 %}
        {% endif %}
      {% endif %}
    {% endfor %}

    {% assign sort_count = live_count %}
    {% if live_count == 0 %}{% assign sort_count = total_count %}{% endif %}
    {% assign padded = '000' | append: sort_count | slice: -3, 3 %}
    {% assign sorted_entry = padded | append: '|' | append: handle %}

    {% if live_count > 0 %}
      {% if active_entries != '' %}{% assign active_entries = active_entries | append: ',' %}{% endif %}
      {% assign active_entries = active_entries | append: sorted_entry %}
    {% else %}
      {% if soon_entries != '' %}{% assign soon_entries = soon_entries | append: ',' %}{% endif %}
      {% assign soon_entries = soon_entries | append: sorted_entry %}
    {% endif %}
  {% endfor %}

  {% assign active_sorted = active_entries | split: ',' | sort | reverse %}
  {% assign soon_sorted = soon_entries | split: ',' | sort | reverse %}

  <div class="conference-nav__list">
    {% for entry in active_sorted %}
      {% assign handle = entry | split: '|' | last %}
      {% assign conference = shop.metaobjects.conference[handle] %}
      <a href="/pages/schools#conference={{ conference.name.value | url_encode | replace: '+', '%20' }}" class="conference-nav__item">
        <div class="conference-nav__circle">
          {% if conference.logo.value %}
            {{ conference.logo.value | image_url: width: 128 | image_tag: loading: 'lazy' }}
          {% else %}
            <span>{{ conference.abbreviation.value }}</span>
          {% endif %}
        </div>
        <span class="conference-nav__name">{{ conference.name.value }}</span>
      </a>
    {% endfor %}

    {% for entry in soon_sorted %}
      {% assign handle = entry | split: '|' | last %}
      {% assign conference = shop.metaobjects.conference[handle] %}
      <a href="/pages/schools#conference={{ conference.name.value | url_encode | replace: '+', '%20' }}" class="conference-nav__item conference-nav__item--coming-soon">
        <div class="conference-nav__circle">
          {% if conference.logo.value %}
            {{ conference.logo.value | image_url: width: 128 | image_tag: loading: 'lazy' }}
          {% else %}
            <span>{{ conference.abbreviation.value }}</span>
          {% endif %}
          <span class="conference-nav__coming-soon">COMING<br>SOON</span>
        </div>
        <span class="conference-nav__name">{{ conference.name.value }}</span>
      </a>
    {% endfor %}
  </div>
</section>

{% stylesheet %}
  .conference-nav {
    padding: 40px var(--page-margin);
    text-align: center;
  }

  .conference-nav__heading {
    font-family: var(--font-heading--family);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-foreground);
    margin-bottom: 28px;
  }

  .conference-nav__list {
    display: flex;
    justify-content: center;
    gap: 20px;
    overflow-x: auto;
    scrollbar-width: none;
    padding: 8px var(--page-margin);
    -webkit-overflow-scrolling: touch;
  }

  .conference-nav__list::-webkit-scrollbar {
    display: none;
  }

  .conference-nav__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }

  .conference-nav__circle {
    position: relative;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background-color: var(--color-cream);
    color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading--family);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    overflow: hidden;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  .conference-nav__circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .conference-nav__item--coming-soon {
    pointer-events: none;
  }

  .conference-nav__item--coming-soon .conference-nav__circle img,
  .conference-nav__item--coming-soon .conference-nav__circle > span:not(.conference-nav__coming-soon) {
    opacity: 0.15;
  }

  .conference-nav__coming-soon {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading--family);
    font-size: 0.45rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    line-height: 1.3;
    text-align: center;
    color: var(--color-foreground);
  }

  .conference-nav__item:hover .conference-nav__circle {
    transform: scale(1.08);
    opacity: 0.85;
  }

  .conference-nav__name {
    font-family: var(--font-body--family);
    font-size: 0.7rem;
    color: var(--color-muted);
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .conference-nav__list {
      justify-content: flex-start;
    }

    .conference-nav__circle {
      width: 52px;
      height: 52px;
      font-size: 0.7rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.conference_nav",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "SHOP BY CONFERENCE"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "t:general.conference_nav"
    }
  ]
}
{% endschema %}
