{%- liquid
  assign marquee_bg = section.settings.background_color
  assign marquee_fg = section.settings.text_color

  if section.settings.use_school_color and product != nil
    paginate shop.metaobjects.school.values by 250
      for col in product.collections
        assign found_school = shop.metaobjects.school.values | where: 'slug', col.handle | first
        if found_school
          capture school_accent
            render 'school-accent-color', school: found_school
          endcapture
          assign marquee_bg = school_accent | strip
          assign marquee_fg = '#FFFFFF'
          break
        endif
      endfor
    endpaginate
  endif
-%}

<marquee-scroll
  class="marquee full-width"
  style="background-color: {{ marquee_bg }}; --marquee-duration: {{ section.settings.speed }}s;"
>
  <div class="marquee__track" data-marquee-track>
    <div class="marquee__content" data-marquee-content>
      {% for block in section.blocks %}
        <span class="marquee__item" style="color: {{ marquee_fg }};" {{ block.shopify_attributes }}>
          {{ block.settings.text }}
        </span>
        <span class="marquee__separator" style="color: {{ marquee_fg }};">✦</span>
      {% endfor %}
    </div>
  </div>
</marquee-scroll>

{% stylesheet %}
  .marquee {
    overflow: hidden;
    padding: 14px 0;
  }

  .marquee__track {
    display: flex;
    width: max-content;
    animation: marquee-scroll var(--marquee-duration, 20s) linear infinite;
  }

  .marquee__content {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .marquee__item {
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    white-space: nowrap;
    padding: 0 16px;
  }

  .marquee__separator {
    font-size: 0.5rem;
    flex-shrink: 0;
  }

  @keyframes marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(var(--marquee-shift, -50%));
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .marquee__track {
      animation: none;
    }
  }
{% endstylesheet %}

<script>
  class MarqueeScroll extends HTMLElement {
    connectedCallback() {
      const track = this.querySelector('[data-marquee-track]');
      const content = this.querySelector('[data-marquee-content]');
      if (!track || !content) return;

      const fill = () => {
        // Remove old clones
        track.querySelectorAll('[data-marquee-clone]').forEach(c => c.remove());

        const contentWidth = content.offsetWidth;
        if (!contentWidth) return;

        // Need enough copies so total width >= 2x viewport (seamless loop)
        const needed = Math.ceil((window.innerWidth * 2) / contentWidth) + 1;

        for (let i = 0; i < needed; i++) {
          const clone = content.cloneNode(true);
          clone.setAttribute('aria-hidden', 'true');
          clone.setAttribute('data-marquee-clone', '');
          track.appendChild(clone);
        }

        // Shift by exactly one content-copy width for a seamless loop
        track.style.setProperty('--marquee-shift', `-${contentWidth}px`);
      };

      fill();

      // Recalculate on resize (font loading can also change widths)
      let resizeTimer;
      window.addEventListener('resize', () => {
        clearTimeout(resizeTimer);
        resizeTimer = setTimeout(fill, 200);
      });

      // Refill after fonts load in case widths changed
      document.fonts?.ready.then(fill);
    }
  }

  if (!customElements.get('marquee-scroll')) {
    customElements.define('marquee-scroll', MarqueeScroll);
  }
</script>

{% schema %}
{
  "name": "t:general.marquee",
  "settings": [
    {
      "type": "checkbox",
      "id": "use_school_color",
      "label": "t:labels.use_school_color",
      "default": false
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#F5F2EB"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.foreground",
      "default": "#FFB800"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "t:labels.speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "phrase",
      "name": "t:labels.text",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:labels.text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.marquee",
      "blocks": [
        { "type": "phrase", "settings": { "text": "CLC CERTIFIED" } },
        { "type": "phrase", "settings": { "text": "AFFINITY LICENSED" } },
        { "type": "phrase", "settings": { "text": "OFFICIALLY LICENSED" } }
      ]
    }
  ]
}
{% endschema %}
