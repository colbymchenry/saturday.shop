{%- comment -%}
  Hero Carousel — full-width slides with per-slide Shopify font pickers.
  Uses blocks (type: slide) so merchants can add / reorder in the theme editor.
{%- endcomment -%}

{%- comment -%} ── Preload custom fonts chosen via font pickers ── {%- endcomment -%}
{%- for block in section.blocks -%}
  {%- assign bold_font = block.settings.font_bold -%}
  {%- assign script_font = block.settings.font_script -%}
  {%- if bold_font.family != blank -%}
    <style>{{ bold_font | font_face: font_display: 'swap' }}</style>
  {%- endif -%}
  {%- if script_font.family != blank -%}
    <style>{{ script_font | font_face: font_display: 'swap' }}</style>
  {%- endif -%}
{%- endfor -%}

<section
  class="hero-banner full-width"
  style="--hero-height: {{ section.settings.height }}vh;"
  data-auto-advance="{{ section.settings.auto_advance }}"
  aria-roledescription="carousel"
  aria-label="Hero slideshow"
>
  {%- comment -%} ── Slide track ── {%- endcomment -%}
  <div class="hero-banner__track">
    {%- for block in section.blocks -%}
      <div
        class="hero-banner__slide{% if forloop.first %} hero-banner__slide--active{% endif %}"
        role="group"
        aria-roledescription="slide"
        aria-label="Slide {{ forloop.index }} of {{ section.blocks.size }}"
        {{ block.shopify_attributes }}
        {%- if block.settings.font_bold.family != blank %}
          style="--slide-font-bold: {{ block.settings.font_bold.family }}, {{ block.settings.font_bold.fallback_families }};{% if block.settings.font_script.family != blank %} --slide-font-script: {{ block.settings.font_script.family }}, {{ block.settings.font_script.fallback_families }};{% endif %}"
        {%- elsif block.settings.font_script.family != blank %}
          style="--slide-font-script: {{ block.settings.font_script.family }}, {{ block.settings.font_script.fallback_families }};"
        {%- endif %}
      >
        {%- if block.settings.image -%}
          <div class="hero-banner__image">
            {{ block.settings.image | image_url: width: 2000 | image_tag: loading: 'eager' }}
          </div>
        {%- else -%}
          <div class="hero-banner__image">
            {{ 'hero-apparel-1' | placeholder_svg_tag }}
          </div>
        {%- endif -%}

        <div class="hero-banner__overlay"></div>

        <div class="hero-banner__content">
          {%- if block.settings.subheading != blank -%}
            <p class="hero-banner__subheading">{{ block.settings.subheading }}</p>
          {%- endif -%}

          {%- if block.settings.heading_bold != blank or block.settings.heading_script != blank -%}
            <h2 class="hero-banner__heading">
              {%- if block.settings.heading_bold != blank -%}
                <span class="hero-banner__heading-bold">{{ block.settings.heading_bold }}</span>
              {%- endif -%}
              {%- if block.settings.heading_script != blank -%}
                <span class="hero-banner__heading-script">{{ block.settings.heading_script }}</span>
              {%- endif -%}
            </h2>
          {%- endif -%}

          {%- if block.settings.description != blank -%}
            <p class="hero-banner__description">{{ block.settings.description }}</p>
          {%- endif -%}

          {%- if block.settings.button_text != blank -%}
            <a href="{{ block.settings.button_url }}" class="hero-banner__button">
              {{ block.settings.button_text }}
            </a>
          {%- endif -%}
        </div>
      </div>
    {%- endfor -%}
  </div>

  {%- if section.blocks.size > 1 -%}
    {%- comment -%} ── Arrow navigation ── {%- endcomment -%}
    <button class="hero-banner__arrow hero-banner__arrow--prev" aria-label="Previous slide">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M13 4L7 10L13 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>
    <button class="hero-banner__arrow hero-banner__arrow--next" aria-label="Next slide">
      <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M7 4L13 10L7 16" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </button>

    {%- comment -%} ── Dot indicators ── {%- endcomment -%}
    <div class="hero-banner__dots" role="tablist" aria-label="Slide navigation">
      {%- for block in section.blocks -%}
        <button
          class="hero-banner__dot{% if forloop.first %} hero-banner__dot--active{% endif %}"
          role="tab"
          aria-selected="{% if forloop.first %}true{% else %}false{% endif %}"
          aria-label="Go to slide {{ forloop.index }}"
          data-index="{{ forloop.index0 }}"
        ></button>
      {%- endfor -%}
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  /* ── Carousel container ── */
  .hero-banner {
    position: relative;
    min-height: var(--hero-height, 80vh);
    overflow: hidden;
  }

  .hero-banner__track {
    display: flex;
    height: 100%;
    position: absolute;
    inset: 0;
    transition: transform 0.6s cubic-bezier(0.25, 0.1, 0.25, 1);
    will-change: transform;
  }

  /* ── Individual slide ── */
  .hero-banner__slide {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-width: 100%;
    min-height: var(--hero-height, 80vh);
    flex-shrink: 0;
  }

  /* ── Image layer ── */
  .hero-banner__image {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero-banner__image img,
  .hero-banner__image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* ── Gradient overlay ── */
  .hero-banner__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.55) 0%,
      rgba(0, 0, 0, 0.2) 40%,
      transparent 70%
    );
    z-index: 1;
  }

  /* ── Content ── */
  .hero-banner__content {
    position: relative;
    z-index: 2;
    padding: 48px clamp(24px, 5vw, 64px);
    color: #fff;
    max-width: 800px;
  }

  .hero-banner__subheading {
    font-family: var(--font-heading--family);
    font-size: clamp(0.75rem, 1.2vw, 0.9rem);
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    margin-bottom: 8px;
    opacity: 0.9;
  }

  .hero-banner__heading {
    font-size: clamp(2.5rem, 6vw, 5rem);
    line-height: 1;
    margin: 0;
  }

  .hero-banner__heading-bold {
    font-family: var(--slide-font-bold, var(--font-heading--family));
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  .hero-banner__heading-script {
    font-family: var(--slide-font-script, var(--font-body--family));
    font-weight: 400;
    font-style: italic;
    margin-left: 0.15em;
  }

  .hero-banner__description {
    font-family: var(--font-body--family);
    font-size: clamp(0.9rem, 1.3vw, 1.05rem);
    font-weight: 400;
    line-height: 1.5;
    margin-top: 12px;
    opacity: 0.9;
  }

  .hero-banner__button {
    display: inline-block;
    margin-top: 24px;
    padding: 14px 32px;
    font-family: var(--font-heading--family);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-foreground);
    background-color: var(--color-background);
    transition: opacity 0.2s ease;
  }

  .hero-banner__button:hover {
    opacity: 0.85;
  }

  /* ── Arrow buttons ── */
  .hero-banner__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border: none;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.15);
    backdrop-filter: blur(4px);
    color: #fff;
    cursor: pointer;
    transition: background 0.2s ease;
  }

  .hero-banner__arrow:hover {
    background: rgba(255, 255, 255, 0.3);
  }

  .hero-banner__arrow--prev { left: 16px; }
  .hero-banner__arrow--next { right: 16px; }

  /* ── Dot indicators ── */
  .hero-banner__dots {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: 10px;
  }

  .hero-banner__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid rgba(255, 255, 255, 0.7);
    background: transparent;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease, border-color 0.2s ease;
  }

  .hero-banner__dot--active {
    background: #fff;
    border-color: #fff;
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .hero-banner {
      min-height: 60vh;
    }

    .hero-banner__slide {
      min-height: 60vh;
    }

    .hero-banner__content {
      padding: 32px 20px;
    }

    .hero-banner__arrow {
      width: 36px;
      height: 36px;
    }

    .hero-banner__arrow--prev { left: 10px; }
    .hero-banner__arrow--next { right: 10px; }

    .hero-banner__dots {
      bottom: 14px;
    }
  }
{% endstylesheet %}

<script>
  (function () {
    var section = document.querySelector('.hero-banner[aria-roledescription="carousel"]');
    if (!section) return;

    var track = section.querySelector('.hero-banner__track');
    var slides = Array.from(section.querySelectorAll('.hero-banner__slide'));
    var dots = Array.from(section.querySelectorAll('.hero-banner__dot'));
    var prevBtn = section.querySelector('.hero-banner__arrow--prev');
    var nextBtn = section.querySelector('.hero-banner__arrow--next');

    if (slides.length <= 1) return;

    var current = 0;
    var autoTimer = null;
    var autoDelay = (parseInt(section.dataset.autoAdvance, 10) || 7) * 1000;

    function goTo(index) {
      current = ((index % slides.length) + slides.length) % slides.length;
      track.style.transform = 'translateX(-' + (current * 100) + '%)';

      slides.forEach(function (s, i) {
        s.classList.toggle('hero-banner__slide--active', i === current);
      });
      dots.forEach(function (d, i) {
        d.classList.toggle('hero-banner__dot--active', i === current);
        d.setAttribute('aria-selected', i === current ? 'true' : 'false');
      });
    }

    function next() { goTo(current + 1); }
    function prev() { goTo(current - 1); }

    function startAuto() {
      stopAuto();
      if (autoDelay > 0) autoTimer = setInterval(next, autoDelay);
    }
    function stopAuto() {
      if (autoTimer) { clearInterval(autoTimer); autoTimer = null; }
    }

    section.addEventListener('mouseenter', stopAuto);
    section.addEventListener('mouseleave', startAuto);
    section.addEventListener('focusin', stopAuto);
    section.addEventListener('focusout', startAuto);

    if (prevBtn) prevBtn.addEventListener('click', function () { prev(); startAuto(); });
    if (nextBtn) nextBtn.addEventListener('click', function () { next(); startAuto(); });

    dots.forEach(function (dot) {
      dot.addEventListener('click', function () {
        goTo(parseInt(dot.dataset.index, 10));
        startAuto();
      });
    });

    section.addEventListener('keydown', function (e) {
      if (e.key === 'ArrowLeft') { prev(); startAuto(); }
      if (e.key === 'ArrowRight') { next(); startAuto(); }
    });

    var pointerStart = null;
    section.addEventListener('pointerdown', function (e) {
      if (e.pointerType === 'mouse') return;
      pointerStart = e.clientX;
      stopAuto();
    });
    section.addEventListener('pointerup', function (e) {
      if (pointerStart === null) return;
      var dx = e.clientX - pointerStart;
      if (Math.abs(dx) > 50) { dx < 0 ? next() : prev(); }
      pointerStart = null;
      startAuto();
    });
    section.addEventListener('pointercancel', function () { pointerStart = null; startAuto(); });

    startAuto();
  })();
</script>

{% schema %}
{
  "name": "Hero carousel",
  "settings": [
    {
      "type": "range",
      "id": "height",
      "label": "t:labels.height",
      "min": 40,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "default": 80
    },
    {
      "type": "range",
      "id": "auto_advance",
      "label": "Auto-advance interval",
      "info": "Seconds between slides. Set to 0 to disable.",
      "min": 0,
      "max": 12,
      "step": 1,
      "unit": "s",
      "default": 7
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.background"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Subheading",
          "default": "IT'S SATURDAY, Y'ALL."
        },
        {
          "type": "text",
          "id": "heading_bold",
          "label": "Heading (bold)",
          "default": "WESTERN"
        },
        {
          "type": "text",
          "id": "heading_script",
          "label": "Heading (script)",
          "default": "Collection"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Spirit of the west, soul of the college tradition."
        },
        {
          "type": "text",
          "id": "button_text",
          "label": "Button text",
          "default": "SHOP THE DROP"
        },
        {
          "type": "url",
          "id": "button_url",
          "label": "Button URL"
        },
        {
          "type": "header",
          "content": "Custom fonts"
        },
        {
          "type": "font_picker",
          "id": "font_bold",
          "label": "Bold heading font",
          "default": "work_sans_n7"
        },
        {
          "type": "font_picker",
          "id": "font_script",
          "label": "Script heading font",
          "default": "work_sans_n4"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero carousel",
      "blocks": [
        {
          "type": "slide"
        }
      ]
    }
  ]
}
{% endschema %}
