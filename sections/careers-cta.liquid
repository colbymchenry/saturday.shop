<section class="careers-cta full-width" style="background-color: {{ section.settings.background_color }};">
  <div class="careers-cta__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="careers-cta__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <div class="careers-cta__heading">{{ section.settings.heading }}</div>
    {% endif %}

    {% if section.settings.body != blank %}
      <p class="careers-cta__body">{{ section.settings.body }}</p>
    {% endif %}

    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_url }}" class="careers-cta__button">
        {{ section.settings.button_text }}
      </a>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .careers-cta {
    display: grid;
    grid-template-columns: var(--content-grid);
    padding: var(--section-padding-block) 0;
  }

  .careers-cta__inner {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .careers-cta__eyebrow {
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent-gold);
    margin-bottom: 24px;
  }

  .careers-cta__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-foreground);
  }

  .careers-cta__heading em {
    font-style: italic;
    font-weight: 800;
  }

  .careers-cta__heading p {
    margin: 0;
  }

  .careers-cta__body {
    font-family: var(--font-body--family);
    font-size: clamp(0.9rem, 1.3vw, 1.05rem);
    line-height: 1.6;
    color: var(--color-muted);
    margin-top: 24px;
    max-width: 540px;
  }

  .careers-cta__button {
    display: inline-block;
    margin-top: 32px;
    padding: 16px 40px;
    font-family: var(--font-heading--family);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-background);
    background-color: var(--color-foreground);
    transition: opacity 0.2s ease;
  }

  .careers-cta__button:hover {
    opacity: 0.85;
  }

{% endstylesheet %}

{% schema %}
{
  "name": "t:general.careers_cta",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#F5F2EB"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "DON'T SEE YOUR ROLE?"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "<p>We're always looking for <em>great people.</em></p>"
    },
    {
      "type": "text",
      "id": "body",
      "label": "t:labels.description",
      "default": "Even if there's nothing open that fits you right now, send us your info. We grow fast and we'd love to keep you in mind."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:labels.button_text",
      "default": "GET IN TOUCH"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:labels.button_url"
    }
  ],
  "presets": [
    {
      "name": "t:general.careers_cta"
    }
  ]
}
{% endschema %}
