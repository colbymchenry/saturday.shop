{% if section.settings.image %}
  <div class="full-width-image full-width full-width-image--{{ section.settings.height }}">
    {% if section.settings.url != blank %}
      <a href="{{ section.settings.url }}">
        {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy' }}
      </a>
    {% else %}
      {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy' }}
    {% endif %}
  </div>
{% else %}
  <div class="full-width-image full-width full-width-image--{{ section.settings.height }}">
    {{ 'lifestyle-1' | placeholder_svg_tag }}
  </div>
{% endif %}

{% stylesheet %}
  .full-width-image {
    line-height: 0;
    overflow: hidden;
  }

  .full-width-image img,
  .full-width-image svg {
    width: 100%;
    height: auto;
  }

  .full-width-image a {
    display: block;
    height: 100%;
  }

  /* Height variants */
  .full-width-image--small {
    max-height: 250px;
  }

  .full-width-image--medium {
    max-height: 450px;
  }

  .full-width-image--large {
    max-height: 650px;
  }

  .full-width-image--small img,
  .full-width-image--small svg,
  .full-width-image--medium img,
  .full-width-image--medium svg,
  .full-width-image--large img,
  .full-width-image--large svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* Auto: no max-height constraint, image displays at natural aspect ratio */
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.full_width_image",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "t:labels.image"
    },
    {
      "type": "url",
      "id": "url",
      "label": "t:labels.url"
    },
    {
      "type": "select",
      "id": "height",
      "label": "Image height",
      "default": "auto",
      "options": [
        { "value": "auto", "label": "Auto (natural)" },
        { "value": "small", "label": "Small (250px)" },
        { "value": "medium", "label": "Medium (450px)" },
        { "value": "large", "label": "Large (650px)" }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.full_width_image"
    }
  ]
}
{% endschema %}
