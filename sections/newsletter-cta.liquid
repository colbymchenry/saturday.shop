<section class="newsletter-cta full-width" style="background-color: {{ section.settings.background_color }};">
  <div class="newsletter-cta__inner">
    {% if section.settings.heading != blank %}
      <h2 class="newsletter-cta__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.body != blank %}
      <p class="newsletter-cta__body">{{ section.settings.body }}</p>
    {% endif %}

    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_url }}" class="newsletter-cta__button">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
        {{ section.settings.button_text }}
      </a>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .newsletter-cta {
    padding: 80px var(--page-margin);
    text-align: center;
  }

  .newsletter-cta__inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    max-width: 540px;
    margin: 0 auto;
  }

  .newsletter-cta__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 800;
    color: var(--color-foreground);
  }

  .newsletter-cta__body {
    font-family: var(--font-body--family);
    font-size: clamp(0.9rem, 1.3vw, 1.05rem);
    line-height: 1.6;
    color: var(--color-muted);
    margin-top: 12px;
  }

  .newsletter-cta__button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 28px;
    padding: 16px 36px;
    font-family: var(--font-heading--family);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-background);
    background-color: var(--color-foreground);
    transition: opacity 0.2s ease;
  }

  .newsletter-cta__button:hover {
    opacity: 0.85;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.newsletter_cta",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Sign Up and Save"
    },
    {
      "type": "text",
      "id": "body",
      "label": "t:labels.description",
      "default": "Subscribe to get special offers, free giveaways, and once-in-a-lifetime deals."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:labels.button_text",
      "default": "SIGN UP & SAVE"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:labels.button_url"
    }
  ],
  "presets": [
    {
      "name": "t:general.newsletter_cta"
    }
  ]
}
{% endschema %}
