{% comment %}
  Frequently Bought Together — shows the current product plus complementary
  product recommendations with checkboxes, total price, and bulk add-to-cart.
  Uses the shared product-card snippet for consistent card rendering.
{% endcomment %}

{{ 'product-card.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-card.js' | asset_url }}" defer="defer"></script>

<frequently-bought
  class="fbt"
  data-product-id="{{ product.id }}"
  hidden
>
  <h2 class="fbt__title">{{ section.settings.heading }}</h2>
  <div class="fbt__rule"></div>

  <div class="fbt__products" data-fbt-products>
    <div class="fbt__item fbt__item--current" data-fbt-item data-checked="true">
      <span class="fbt__item-label">This item</span>
      <div class="fbt__item-card">
        <div class="fbt__checkbox fbt__checkbox--checked" data-fbt-checkbox>
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
        </div>
        {% render 'product-card', product: product %}
      </div>
    </div>
  </div>

  <div class="fbt__footer" data-fbt-footer hidden>
    <div class="fbt__total">
      <span class="fbt__total-label">TOTAL PRICE:</span>
      <span class="fbt__total-price" data-fbt-total></span>
    </div>
    <button type="button" class="fbt__add-all" data-fbt-add-all>
      ADD ALL <span data-fbt-count>1</span> TO CART
    </button>
  </div>
</frequently-bought>

{% stylesheet %}
  .fbt {
    padding: 4rem var(--page-margin);
    text-align: center;
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .fbt[hidden] {
    display: none;
  }

  .fbt__title {
    font-family: var(--font-heading--family);
    font-size: clamp(1rem, 2vw, 1.3rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin: 0;
  }

  .fbt__rule {
    width: 40px;
    height: 3px;
    background: var(--color-foreground);
    margin: 1rem auto 2.5rem;
  }

  /* ── Product cards row ── */
  .fbt__products {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 0;
    flex-wrap: wrap;
  }

  .fbt__item {
    width: 250px;
    flex-shrink: 0;
    text-align: left;
  }

  .fbt__item-label {
    display: block;
    font-family: var(--font-heading--family);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    opacity: 0.5;
    margin-bottom: 0.5rem;
  }

  .fbt__item-card {
    position: relative;
  }

  .fbt__item-card .product-card {
    border: 1px solid var(--color-border);
  }

  .fbt__plus {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    align-self: center;
    font-size: 1.5rem;
    color: var(--color-foreground);
    opacity: 0.3;
    flex-shrink: 0;
  }

  /* ── Checkbox ── */
  .fbt__checkbox {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 24px;
    height: 24px;
    border: 2px solid var(--color-border);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    background: transparent;
    z-index: 3;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }

  .fbt__checkbox svg {
    opacity: 0;
  }

  .fbt__checkbox--checked {
    background: var(--color-foreground);
    border-color: var(--color-foreground);
  }

  .fbt__checkbox--checked svg {
    opacity: 1;
  }

  /* ── Footer ── */
  .fbt__footer {
    margin-top: 2rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .fbt__footer[hidden] {
    display: none;
  }

  .fbt__total {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
  }

  .fbt__total-label {
    font-family: var(--font-heading--family);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .fbt__total-price {
    font-family: var(--font-body--family);
    font-size: 1.1rem;
    font-weight: 700;
  }

  .fbt__add-all {
    padding: 1rem 3rem;
    font-family: var(--font-heading--family);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    background: var(--color-foreground);
    color: var(--color-background);
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .fbt__add-all:hover {
    opacity: 0.85;
  }

  @media (max-width: 768px) {
    .fbt__products {
      flex-direction: column;
      align-items: center;
    }

    .fbt__plus {
      transform: rotate(90deg);
      width: auto;
      height: 32px;
    }

    .fbt__item {
      width: 280px;
    }
  }
{% endstylesheet %}

<script>
  class FrequentlyBought extends HTMLElement {
    connectedCallback() {
      this.productId = this.dataset.productId;
      this.productsContainer = this.querySelector('[data-fbt-products]');
      this.footer = this.querySelector('[data-fbt-footer]');
      this.totalEl = this.querySelector('[data-fbt-total]');
      this.countEl = this.querySelector('[data-fbt-count]');
      this.addAllBtn = this.querySelector('[data-fbt-add-all]');

      var currentCheckbox = this.querySelector('.fbt__item--current [data-fbt-checkbox]');
      if (currentCheckbox) {
        currentCheckbox.addEventListener('click', () => this.toggleItem(currentCheckbox.closest('[data-fbt-item]')));
      }

      this.addEventListener('variant:change', () => this.updateTotal());
      this.addAllBtn.addEventListener('click', () => this.addAllToCart());

      this.fetchRecommendations();
    }

    async fetchRecommendations() {
      try {
        var products = await this.fetchIntent('complementary');
        if (products.length === 0) {
          products = await this.fetchIntent('related');
        }
        if (products.length === 0) return;
        products = products.slice(0, 2);

        await this.renderRecommendations(products);
        this.hidden = false;
        this.footer.hidden = false;
        this.updateTotal();
      } catch {}
    }

    async fetchIntent(intent) {
      var res = await fetch(
        '/recommendations/products.json?product_id=' + this.productId + '&limit=4&intent=' + intent
      );
      if (!res.ok) return [];
      var data = await res.json();
      return data.products || [];
    }

    async renderRecommendations(products) {
      var results = await Promise.all(
        products.map(function(product) {
          return fetch('/products/' + product.handle + '?section_id=product-card-render')
            .then(function(res) { return res.ok ? res.text() : null; })
            .catch(function() { return null; });
        })
      );

      results.forEach(function(html) {
        if (!html) return;

        var match = html.match(/<product-card[\s\S]*<\/product-card>/);
        if (!match) return;

        var plus = document.createElement('div');
        plus.className = 'fbt__plus';
        plus.textContent = '+';
        this.productsContainer.appendChild(plus);

        var item = document.createElement('div');
        item.className = 'fbt__item';
        item.dataset.fbtItem = '';
        item.dataset.checked = 'true';
        item.innerHTML =
          '<div class="fbt__item-card">' +
            '<div class="fbt__checkbox fbt__checkbox--checked" data-fbt-checkbox>' +
              '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' +
            '</div>' +
            match[0] +
          '</div>';

        item.querySelector('[data-fbt-checkbox]').addEventListener('click', () => this.toggleItem(item));
        this.productsContainer.appendChild(item);
      }.bind(this));
    }

    toggleItem(item) {
      var isChecked = item.dataset.checked === 'true';
      item.dataset.checked = isChecked ? 'false' : 'true';
      var cb = item.querySelector('[data-fbt-checkbox]');
      cb.classList.toggle('fbt__checkbox--checked', !isChecked);
      this.updateTotal();
    }

    getItemPrice(item) {
      var card = item.querySelector('product-card');
      if (!card) return 0;
      var variantsEl = card.querySelector('[data-variants]');
      var variantInput = card.querySelector('[data-variant-id]');
      if (!variantsEl || !variantInput) return 0;

      try {
        var variants = JSON.parse(variantsEl.textContent);
        var selectedId = parseInt(variantInput.value);
        var variant = variants.find(function(v) { return v.id === selectedId; });
        return variant ? variant.price : 0;
      } catch { return 0; }
    }

    formatMoney(cents) {
      return '$' + (cents / 100).toFixed(2);
    }

    updateTotal() {
      var items = this.querySelectorAll('[data-fbt-item][data-checked="true"]');
      var total = 0;
      items.forEach(function(item) {
        total += this.getItemPrice(item);
      }.bind(this));
      this.totalEl.textContent = this.formatMoney(total);
      this.countEl.textContent = items.length;
    }

    async addAllToCart() {
      var items = this.querySelectorAll('[data-fbt-item][data-checked="true"]');
      var cartItems = [];

      items.forEach(function(item) {
        var card = item.querySelector('product-card');
        if (!card) return;
        var variantInput = card.querySelector('[data-variant-id]');
        if (variantInput) {
          cartItems.push({ id: parseInt(variantInput.value), quantity: 1 });
        }
      });

      if (cartItems.length === 0) return;

      this.addAllBtn.disabled = true;
      this.addAllBtn.textContent = 'ADDING...';

      try {
        await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: cartItems }),
        });
        this.addAllBtn.textContent = 'ADDED!';
        var self = this;
        setTimeout(function() {
          self.addAllBtn.disabled = false;
          self.addAllBtn.innerHTML = 'ADD ALL <span data-fbt-count>' + self.querySelectorAll('[data-fbt-item][data-checked="true"]').length + '</span> TO CART';
          self.countEl = self.querySelector('[data-fbt-count]');
        }, 1500);
      } catch {
        this.addAllBtn.disabled = false;
        this.addAllBtn.textContent = 'ERROR — TRY AGAIN';
      }
    }
  }

  if (!customElements.get('frequently-bought')) {
    customElements.define('frequently-bought', FrequentlyBought);
  }
</script>

{% schema %}
{
  "name": "Bought Together",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Bought Together"
    }
  ]
}
{% endschema %}
