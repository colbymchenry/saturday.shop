{% comment %}
  Frequently Bought Together — shows the current product plus companion
  products (sourced from product tags) with checkboxes, total price,
  and bulk add-to-cart.

  Tag convention: add tags prefixed with "fbt:" followed by the companion
  product's handle. Example: fbt:auburn-vintage-tee, fbt:gameday-hat.
  Up to 2 companion products are shown.
{% endcomment %}


{%- liquid
  assign fbt_handles = ''
  for tag in product.tags
    assign tag_prefix = tag | slice: 0, 4
    if tag_prefix == 'fbt:'
      assign handle = tag | slice: 4, 200
      if fbt_handles == ''
        assign fbt_handles = handle
      else
        assign fbt_handles = fbt_handles | append: ',' | append: handle
      endif
    endif
  endfor
-%}

<frequently-bought
  class="fbt"
  data-product-id="{{ product.id }}"
  {% if fbt_handles != '' %}data-fbt-handles="{{ fbt_handles }}"{% endif %}
  hidden
>
  <h2 class="fbt__title">{{ section.settings.heading }}</h2>

  <div class="fbt__products" data-fbt-products>
    <div class="fbt__item fbt__item--current" data-fbt-item data-checked="true" data-fbt-variants="{{ product.variants | json | escape }}">
      <div class="fbt__checkbox fbt__checkbox--checked" data-fbt-checkbox>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
      </div>
      <img class="fbt__thumb" src="{{ product.featured_image | image_url: width: 200 }}" alt="{{ product.featured_image.alt | escape }}" width="70" height="70" loading="lazy">
      <div class="fbt__details">
        <div class="fbt__row-header">
          <span class="fbt__product-title">{{ product.title }}</span>
          <span class="fbt__product-price" data-fbt-price>{{ product.selected_or_first_available_variant.price | money }}</span>
        </div>
        {%- if product.variants.size > 1 -%}
          <select class="fbt__variant-select" data-fbt-variant-select>
            {%- for variant in product.variants -%}
              <option value="{{ variant.id }}" {% if variant == product.selected_or_first_available_variant %}selected{% endif %}>
                {{ variant.title }}
              </option>
            {%- endfor -%}
          </select>
        {%- endif -%}
        <input type="hidden" data-variant-id value="{{ product.selected_or_first_available_variant.id }}">
      </div>
    </div>
  </div>

  <div class="fbt__footer" data-fbt-footer hidden>
    <div class="fbt__total">
      <span class="fbt__total-label">TOTAL PRICE:</span>
      <span class="fbt__total-price" data-fbt-total></span>
    </div>
    <button type="button" class="fbt__add-all" data-fbt-add-all>
      ADD ALL <span data-fbt-count>1</span> TO CART
    </button>
  </div>
</frequently-bought>

{% stylesheet %}
  .fbt {
    display: block;
    padding: var(--section-padding-block) 0;
    overflow: hidden;
  }

  .fbt[hidden] { display: none; }

  .fbt__title {
    font-family: var(--font-heading--family);
    font-size: clamp(0.85rem, 2vw, 1.1rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    text-align: center;
    margin: 0 0 1.25rem;
  }

  .fbt__products {
    display: flex;
    flex-direction: column;
  }

  .fbt__item {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .fbt__item:first-child {
    border-top: 1px solid var(--color-border);
  }

  .fbt__checkbox {
    width: 22px;
    height: 22px;
    border: 2px solid var(--color-border);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    background: transparent;
    flex-shrink: 0;
    transition: background-color 0.15s ease, border-color 0.15s ease;
  }

  .fbt__checkbox svg { opacity: 0; }

  .fbt__checkbox--checked {
    background: var(--color-foreground);
    border-color: var(--color-foreground);
  }

  .fbt__checkbox--checked svg { opacity: 1; }

  .fbt__thumb {
    width: 60px;
    height: 60px;
    object-fit: cover;
    border-radius: 6px;
    flex-shrink: 0;
    background: var(--color-border);
  }

  .fbt__details {
    flex: 1;
    min-width: 0;
  }

  .fbt__row-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 0.5rem;
    min-width: 0;
  }

  .fbt__product-title {
    font-family: var(--font-body--family);
    font-size: 0.85rem;
    font-weight: 600;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .fbt__product-price {
    font-family: var(--font-body--family);
    font-size: 0.85rem;
    font-weight: 700;
    flex-shrink: 0;
  }

  .fbt__variant-select {
    display: block;
    font-family: var(--font-body--family);
    font-size: 0.75rem;
    color: rgba(0, 0, 0, 0.5);
    border: none;
    background: none;
    padding: 0.15rem 0 0;
    margin: 0;
    cursor: pointer;
  }

  .fbt__footer {
    margin-top: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .fbt__footer[hidden] { display: none; }

  .fbt__total {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .fbt__total-label {
    font-family: var(--font-heading--family);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .fbt__total-price {
    font-family: var(--font-body--family);
    font-size: 1rem;
    font-weight: 700;
  }

  .fbt__add-all {
    width: 100%;
    padding: 0.875rem;
    font-family: var(--font-heading--family);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border: none;
    background: var(--color-foreground);
    color: var(--color-background);
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .fbt__add-all:hover { opacity: 0.85; }

  @media (min-width: 769px) {
    .fbt__footer { align-items: center; }
    .fbt__total { justify-content: center; gap: 0.5rem; }
    .fbt__add-all { width: auto; padding: 0.875rem 3rem; }
  }
{% endstylesheet %}

<script>
  class FrequentlyBought extends HTMLElement {
    connectedCallback() {
      this.productId = this.dataset.productId;
      this.productsContainer = this.querySelector('[data-fbt-products]');
      this.footer = this.querySelector('[data-fbt-footer]');
      this.totalEl = this.querySelector('[data-fbt-total]');
      this.countEl = this.querySelector('[data-fbt-count]');
      this.addAllBtn = this.querySelector('[data-fbt-add-all]');

      var currentItem = this.querySelector('.fbt__item--current');
      var currentCheckbox = currentItem && currentItem.querySelector('[data-fbt-checkbox]');
      if (currentCheckbox) {
        currentCheckbox.addEventListener('click', () => this.toggleItem(currentItem));
      }
      var currentSelect = currentItem && currentItem.querySelector('[data-fbt-variant-select]');
      if (currentSelect) {
        currentSelect.addEventListener('change', () => this.onVariantChange(currentItem));
      }

      this.addAllBtn.addEventListener('click', () => this.addAllToCart());
      this.loadCompanions();
    }

    async loadCompanions() {
      var handlesAttr = this.dataset.fbtHandles;
      if (!handlesAttr) return;

      var handles = handlesAttr.split(',').slice(0, 2);
      if (handles.length === 0) return;

      try {
        await this.renderCompanions(handles);
        if (this.querySelectorAll('[data-fbt-item]:not(.fbt__item--current)').length === 0) return;
        this.hidden = false;
        this.footer.hidden = false;
        this.updateTotal();
      } catch {}
    }

    async renderCompanions(handles) {
      var results = await Promise.all(
        handles.map(function(handle) {
          return fetch('/products/' + handle + '.js')
            .then(function(res) { return res.ok ? res.json() : null; })
            .catch(function() { return null; });
        })
      );

      results.forEach(function(product) {
        if (!product || !product.variants || product.variants.length === 0) return;

        var variant = product.variants[0];
        var imgSrc = product.featured_image || '';
        if (imgSrc) {
          var sep = imgSrc.indexOf('?') > -1 ? '&' : '?';
          imgSrc += sep + 'width=200&height=200&crop=center';
        }

        var showSelect = product.variants.length > 1 ||
          (product.variants.length === 1 && variant.title !== 'Default Title');
        var variantOptions = '';
        if (showSelect) {
          variantOptions = '<select class="fbt__variant-select" data-fbt-variant-select>' +
            product.variants.map(function(v) {
              return '<option value="' + v.id + '"' +
                (v.id === variant.id ? ' selected' : '') + '>' +
                this.escapeHtml(v.title) + '</option>';
            }.bind(this)).join('') + '</select>';
        }

        var item = document.createElement('div');
        item.className = 'fbt__item';
        item.dataset.fbtItem = '';
        item.dataset.checked = 'true';
        item.dataset.fbtVariants = JSON.stringify(product.variants);
        item.innerHTML =
          '<div class="fbt__checkbox fbt__checkbox--checked" data-fbt-checkbox>' +
            '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>' +
          '</div>' +
          '<img class="fbt__thumb" src="' + imgSrc + '" alt="" width="70" height="70" loading="lazy">' +
          '<div class="fbt__details">' +
            '<div class="fbt__row-header">' +
              '<span class="fbt__product-title">' + this.escapeHtml(product.title) + '</span>' +
              '<span class="fbt__product-price" data-fbt-price>' + this.formatMoney(variant.price) + '</span>' +
            '</div>' +
            variantOptions +
            '<input type="hidden" data-variant-id value="' + variant.id + '">' +
          '</div>';

        item.querySelector('[data-fbt-checkbox]').addEventListener('click', () => this.toggleItem(item));
        var select = item.querySelector('[data-fbt-variant-select]');
        if (select) {
          select.addEventListener('change', () => this.onVariantChange(item));
        }
        this.productsContainer.appendChild(item);
      }.bind(this));
    }

    escapeHtml(str) {
      var div = document.createElement('div');
      div.textContent = str;
      return div.innerHTML;
    }

    onVariantChange(item) {
      var select = item.querySelector('[data-fbt-variant-select]');
      var variantInput = item.querySelector('[data-variant-id]');
      var priceEl = item.querySelector('[data-fbt-price]');
      if (!select || !variantInput || !item.dataset.fbtVariants) return;

      variantInput.value = select.value;
      try {
        var variants = JSON.parse(item.dataset.fbtVariants);
        var variant = variants.find(function(v) { return v.id === parseInt(select.value); });
        if (variant && priceEl) priceEl.textContent = this.formatMoney(variant.price);
      } catch {}
      this.updateTotal();
    }

    toggleItem(item) {
      var isChecked = item.dataset.checked === 'true';
      item.dataset.checked = isChecked ? 'false' : 'true';
      var cb = item.querySelector('[data-fbt-checkbox]');
      cb.classList.toggle('fbt__checkbox--checked', !isChecked);
      this.updateTotal();
    }

    getItemPrice(item) {
      var variantInput = item.querySelector('[data-variant-id]');
      if (!item.dataset.fbtVariants || !variantInput) return 0;

      try {
        var variants = JSON.parse(item.dataset.fbtVariants);
        var selectedId = parseInt(variantInput.value);
        var variant = variants.find(function(v) { return v.id === selectedId; });
        return variant ? variant.price : 0;
      } catch { return 0; }
    }

    formatMoney(cents) {
      return '$' + (cents / 100).toFixed(2);
    }

    updateTotal() {
      var items = this.querySelectorAll('[data-fbt-item][data-checked="true"]');
      var total = 0;
      items.forEach(function(item) {
        total += this.getItemPrice(item);
      }.bind(this));
      this.totalEl.textContent = this.formatMoney(total);
      this.countEl.textContent = items.length;
    }

    async addAllToCart() {
      var items = this.querySelectorAll('[data-fbt-item][data-checked="true"]');
      var cartItems = [];

      items.forEach(function(item) {
        var variantInput = item.querySelector('[data-variant-id]');
        if (variantInput) {
          cartItems.push({ id: parseInt(variantInput.value), quantity: 1 });
        }
      });

      if (cartItems.length === 0) return;

      this.addAllBtn.disabled = true;
      this.addAllBtn.textContent = 'ADDING...';

      try {
        await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ items: cartItems }),
        });
        this.addAllBtn.textContent = 'ADDED!';
        var self = this;
        setTimeout(function() {
          self.addAllBtn.disabled = false;
          self.addAllBtn.innerHTML = 'ADD ALL <span data-fbt-count>' + self.querySelectorAll('[data-fbt-item][data-checked="true"]').length + '</span> TO CART';
          self.countEl = self.querySelector('[data-fbt-count]');
        }, 1500);
      } catch {
        this.addAllBtn.disabled = false;
        this.addAllBtn.textContent = 'ERROR — TRY AGAIN';
      }
    }
  }

  if (!customElements.get('frequently-bought')) {
    customElements.define('frequently-bought', FrequentlyBought);
  }
</script>

{% schema %}
{
  "name": "Bought Together",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Bought Together"
    }
  ]
}
{% endschema %}
