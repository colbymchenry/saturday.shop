{%- if section.blocks.size > 0 -%}
  <div class="trust-badges">
    {%- for block in section.blocks -%}
      <div class="trust-badges__item" {{ block.shopify_attributes }}>
        {%- if block.settings.icon != blank -%}
          <img
            src="{{ block.settings.icon | asset_url }}"
            alt=""
            width="24"
            height="24"
            loading="lazy"
            class="trust-badges__icon"
          >
        {%- endif -%}
        <span class="trust-badges__label">{{ block.settings.label }}</span>
      </div>
    {%- endfor -%}
  </div>
{%- endif -%}

{% stylesheet %}
  .trust-badges {
    display: flex;
    align-items: flex-start;
    justify-content: center;
    gap: 1.5rem;
    padding: 1rem 0;
  }

  .trust-badges__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.4rem;
    flex: 1;
    max-width: 10rem;
  }

  .trust-badges__icon {
    width: 24px;
    height: 24px;
    object-fit: contain;
    opacity: 0.7;
  }

  .trust-badges__label {
    font-family: var(--font-body--family);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--color-foreground);
    opacity: 0.6;
    line-height: 1.3;
  }

  @media screen and (max-width: 749px) {
    .trust-badges {
      flex-direction: column;
      align-items: stretch;
      gap: 0.75rem;
    }

    .trust-badges__item {
      flex-direction: row;
      text-align: left;
      gap: 0.75rem;
      max-width: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Trust Badges",
  "settings": [],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon filename",
          "default": "icon-licensed.svg",
          "info": "SVG filename from assets/ (e.g., icon-licensed.svg)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Trust badge"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Badges"
    }
  ]
}
{% endschema %}
