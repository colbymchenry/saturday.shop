<section class="careers-perks full-width" style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};">
  <div class="careers-perks__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="careers-perks__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="careers-perks__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="careers-perks__grid">
      {% for block in section.blocks %}
        <div class="careers-perks__item" {{ block.shopify_attributes }}>
          <span class="careers-perks__number">{% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}</span>
          <div class="careers-perks__divider"></div>
          <h3 class="careers-perks__item-heading">{{ block.settings.heading }}</h3>
          {% if block.settings.body != blank %}
            <p class="careers-perks__item-body">{{ block.settings.body }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .careers-perks {
    display: grid;
    grid-template-columns: var(--content-grid);
    padding: 100px 0;
  }

  .careers-perks__inner {
    grid-column: 2;
  }

  .careers-perks__eyebrow {
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent-gold);
    margin-bottom: 20px;
    text-align: center;
  }

  .careers-perks__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 800;
    line-height: 1.15;
    text-align: center;
    margin: 0 0 72px;
  }

  .careers-perks__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 48px;
  }

  .careers-perks__item {
    display: flex;
    flex-direction: column;
  }

  .careers-perks__number {
    font-family: var(--font-heading--family);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 800;
    line-height: 1;
    color: var(--color-accent-gold);
    opacity: 0.35;
  }

  .careers-perks__divider {
    width: 32px;
    height: 1px;
    background-color: currentColor;
    opacity: 0.2;
    margin: 20px 0;
  }

  .careers-perks__item-heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }

  .careers-perks__item-body {
    font-family: var(--font-body--family);
    font-size: clamp(0.85rem, 1.1vw, 0.95rem);
    line-height: 1.65;
    opacity: 0.7;
    margin-top: 12px;
  }

  @media (max-width: 900px) {
    .careers-perks {
      padding: 72px 0;
    }

    .careers-perks__heading {
      margin-bottom: 48px;
    }

    .careers-perks__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 32px;
    }
  }

  @media (max-width: 500px) {
    .careers-perks__grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.careers_perks",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.foreground",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "WHY SATURDAY CO"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "More than just a job."
    }
  ],
  "blocks": [
    {
      "type": "perk",
      "name": "t:general.careers_perk",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "t:labels.description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.careers_perks",
      "blocks": [
        {
          "type": "perk",
          "settings": {
            "heading": "Creative Freedom",
            "body": "Every team member has a voice in the design process. We believe the best ideas come from real passion — not a top-down brief."
          }
        },
        {
          "type": "perk",
          "settings": {
            "heading": "Remote-First",
            "body": "Work from wherever you do your best thinking. We're distributed across the country, connected by Slack and a shared obsession with college culture."
          }
        },
        {
          "type": "perk",
          "settings": {
            "heading": "Campus Research Trips",
            "body": "Yes, visiting college campuses is part of the job. We send team members to experience the traditions and energy firsthand."
          }
        },
        {
          "type": "perk",
          "settings": {
            "heading": "Gear Allowance",
            "body": "Generous product allowance so you can wear what we make. Plus early access to every new drop before it hits the site."
          }
        }
      ]
    }
  ]
}
{% endschema %}
