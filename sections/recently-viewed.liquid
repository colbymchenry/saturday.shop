<section class="recently-viewed" style="background-color: {{ section.settings.background_color }};">
  <h2 class="recently-viewed__title">{{ section.settings.heading }}</h2>

  <product-carousel class="recently-viewed__carousel">
    <button class="featured-collection__arrow featured-collection__arrow--prev" data-dir="prev" aria-label="Previous">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>

    <div class="featured-collection__track" data-recently-viewed-track></div>

    <button class="featured-collection__arrow featured-collection__arrow--next" data-dir="next" aria-label="Next">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  </product-carousel>
</section>

{% comment %} Track current product if on a product page {% endcomment %}
{% if product %}
  <script data-recently-viewed-tracking type="application/json">
    {
      "handle": {{ product.handle | json }},
      "title": {{ product.title | json }},
      "url": {{ product.url | json }},
      "price": {{ product.price | money | json }},
      "compare_at_price": {% if product.compare_at_price > product.price %}{{ product.compare_at_price | money | json }}{% else %}null{% endif %},
      "image": {{ product.featured_image | image_url: width: 600 | json }},
      "tags": {{ product.tags | json }},
      "on_sale": {% if product.compare_at_price > product.price %}true{% else %}false{% endif %}
    }
  </script>
{% endif %}

{% stylesheet %}
  .recently-viewed {
    padding: 48px 0;
  }

  .recently-viewed__title {
    font-family: var(--font-heading--family);
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin-bottom: 24px;
  }

  .recently-viewed__carousel {
    display: flex;
    align-items: center;
    position: relative;
  }

  .recently-viewed[hidden] {
    display: none;
  }
{% endstylesheet %}

{% javascript %}
  const STORAGE_KEY = 'saturday-recently-viewed';
  const MAX_ITEMS = 10;

  function getRecentlyViewed() {
    try {
      return JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];
    } catch { return []; }
  }

  function saveRecentlyViewed(items) {
    try {
      localStorage.setItem(STORAGE_KEY, JSON.stringify(items));
    } catch {}
  }

  // Track product view
  const trackingEl = document.querySelector('[data-recently-viewed-tracking]');
  if (trackingEl) {
    const product = JSON.parse(trackingEl.textContent);
    const items = getRecentlyViewed().filter(p => p.handle !== product.handle);
    items.unshift(product);
    saveRecentlyViewed(items.slice(0, MAX_ITEMS));
  }

  // Render recently viewed
  const track = document.querySelector('[data-recently-viewed-track]');
  if (track) {
    const items = getRecentlyViewed();
    const currentHandle = trackingEl ? JSON.parse(trackingEl.textContent).handle : null;
    const filtered = items.filter(p => p.handle !== currentHandle);

    if (filtered.length === 0) {
      track.closest('.recently-viewed').hidden = true;
    } else {
      track.innerHTML = filtered.map(product => `
        <div class="product-card">
          <div class="product-card__info">
            <h3 class="product-card__title">
              <a href="${product.url}">${product.title}</a>
            </h3>
            <div class="product-card__price">
              <span class="product-card__current-price">${product.price}</span>
              ${product.compare_at_price ? `<span class="product-card__compare-price">${product.compare_at_price}</span>` : ''}
            </div>
          </div>
          <div class="product-card__media">
            ${product.tags && product.tags.includes('new') ? '<span class="product-card__badge product-card__badge--new">NEW</span>' : ''}
            ${product.on_sale ? '<span class="product-card__badge product-card__badge--sale">SALE</span>' : ''}
            <div class="product-card__images">
              <div class="product-card__image-slide product-card__image-slide--active">
                <a href="${product.url}">
                  <img src="${product.image}" alt="${product.title}" loading="lazy" width="600">
                </a>
              </div>
            </div>
          </div>
        </div>
      `).join('');
    }
  }
{% endjavascript %}

{% schema %}
{
  "name": "t:general.recently_viewed",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "RECENTLY VIEWED"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#F5F2EB"
    }
  ],
  "presets": [
    {
      "name": "t:general.recently_viewed"
    }
  ]
}
{% endschema %}
