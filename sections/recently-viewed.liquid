{{ 'product-card.css' | asset_url | stylesheet_tag }}
<script src="{{ 'product-card.js' | asset_url }}" defer="defer"></script>

<section class="recently-viewed full-width" style="background-color: {{ section.settings.background_color }};" hidden>
  <h2 class="recently-viewed__title" data-recently-viewed-heading {% if section.settings.fallback_heading != blank %}data-fallback-heading="{{ section.settings.fallback_heading | escape }}"{% endif %}>{{ section.settings.heading | escape }}</h2>

  <div class="recently-viewed__carousel" data-recently-viewed-main>
    <button class="recently-viewed__arrow recently-viewed__arrow--prev" data-dir="prev" aria-label="Previous">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>

    <div class="recently-viewed__track" data-recently-viewed-track></div>

    <button class="recently-viewed__arrow recently-viewed__arrow--next" data-dir="next" aria-label="Next">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>
  </div>

  {% if section.settings.fallback_collection != blank and section.settings.fallback_collection.products.size > 0 %}
    <div class="recently-viewed__fallback" data-recently-viewed-fallback hidden>
      <div class="recently-viewed__carousel">
        <button class="recently-viewed__arrow recently-viewed__arrow--prev" data-dir="prev" aria-label="Previous">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
        </button>

        <div class="recently-viewed__track" data-recently-viewed-fallback-track>
          {% for product in section.settings.fallback_collection.products limit: 10 %}
            {% render 'product-card', product: product %}
          {% endfor %}
        </div>

        <button class="recently-viewed__arrow recently-viewed__arrow--next" data-dir="next" aria-label="Next">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  {% endif %}
</section>

{% if product %}
  <script data-recently-viewed-tracking type="application/json">
    {{ product.handle | json }}
  </script>
{% endif %}

{% stylesheet %}
  .recently-viewed {
    padding: 48px 0;
    overflow: hidden;
  }

  .recently-viewed[hidden] {
    display: none;
  }

  .recently-viewed__title {
    font-family: var(--font-heading--family);
    font-size: clamp(1.4rem, 2.5vw, 1.8rem);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    margin-bottom: 24px;
    padding-left: var(--page-margin);
    padding-right: var(--page-margin);
  }

  [data-recently-viewed-main][hidden] {
    display: none;
  }

  .recently-viewed__carousel {
    display: flex;
    align-items: center;
    position: relative;
    width: 100%;
  }

  .recently-viewed__track {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
    width: 100%;
    padding-left: var(--page-margin);
  }

  .recently-viewed__track::-webkit-scrollbar {
    display: none;
  }

  .recently-viewed__arrow {
    position: absolute;
    z-index: 3;
    background: var(--color-background);
    border: 1.5px solid var(--color-border);
    border-radius: 50%;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-foreground);
    transition: opacity 0.2s ease;
  }

  .recently-viewed__arrow:hover {
    opacity: 0.7;
  }

  .recently-viewed__arrow--prev {
    left: 4px;
  }

  .recently-viewed__arrow--next {
    right: 12px;
  }

  .recently-viewed__track .product-card {
    flex: 0 0 18%;
    min-width: 240px;
    scroll-snap-align: start;
    border: 1px solid var(--color-border);
    border-right: none;
  }

  .recently-viewed__track .product-card:last-child {
    border-right: 1px solid var(--color-border);
  }

  @media (max-width: 1024px) {
    .recently-viewed__track .product-card {
      flex: 0 0 28%;
    }

    .recently-viewed__arrow {
      display: none;
    }
  }

  @media (max-width: 600px) {
    .recently-viewed__track .product-card {
      flex: 0 0 65%;
    }
  }
{% endstylesheet %}

<script>
  (function() {
    var sectionRoot = document.currentScript.closest('.shopify-section');
    if (!sectionRoot) return;

    var STORAGE_KEY = 'saturday-recently-viewed';
    var MAX_ITEMS = 10;

    function getHandles() {
      try {
        var items = JSON.parse(localStorage.getItem(STORAGE_KEY)) || [];
        return items.map(function(item) { return typeof item === 'string' ? item : item.handle; }).filter(Boolean);
      } catch(e) { return []; }
    }

    function saveHandles(handles) {
      try { localStorage.setItem(STORAGE_KEY, JSON.stringify(handles)); }
      catch(e) {}
    }

    function wireArrows(container, track) {
      container.querySelectorAll('[data-dir]').forEach(function(btn) {
        btn.addEventListener('click', function() {
          var card = track.querySelector('.product-card');
          if (!card) return;
          track.scrollBy({
            left: btn.dataset.dir === 'next' ? card.offsetWidth : -card.offsetWidth,
            behavior: 'smooth'
          });
        });
      });
    }

    // Track current product
    var trackingEl = sectionRoot.querySelector('[data-recently-viewed-tracking]');
    if (trackingEl) {
      var handle = JSON.parse(trackingEl.textContent);
      var stored = getHandles().filter(function(h) { return h !== handle; });
      stored.unshift(handle);
      saveHandles(stored.slice(0, MAX_ITEMS));
    }

    var section = sectionRoot.querySelector('.recently-viewed');
    var track = sectionRoot.querySelector('[data-recently-viewed-track]');
    var mainCarousel = sectionRoot.querySelector('[data-recently-viewed-main]');
    var fallback = sectionRoot.querySelector('[data-recently-viewed-fallback]');
    var fallbackTrack = sectionRoot.querySelector('[data-recently-viewed-fallback-track]');
    var headingEl = sectionRoot.querySelector('[data-recently-viewed-heading]');

    if (!section || !track) return;

    // Design mode: show everything for merchant preview
    if (window.Shopify && window.Shopify.designMode) {
      section.hidden = false;
      if (mainCarousel && track && track.children.length === 0) {
        mainCarousel.hidden = true;
      }
      if (fallback) fallback.hidden = false;
      if (fallbackTrack) wireArrows(fallback, fallbackTrack);
      wireArrows(mainCarousel || section, track);
      return;
    }

    function isValidHandle(h) {
      return /^[a-z0-9-]+$/.test(h);
    }

    var handles = getHandles();
    var currentHandle = handle || null;
    var filtered = handles.filter(function(h) { return h !== currentHandle; }).filter(isValidHandle);

    if (filtered.length > 0) {
      // State 1: Has recently viewed products — fetch and render
      Promise.all(
        filtered.map(function(h) {
          return fetch('/products/' + h + '?section_id=product-card-render')
            .then(function(res) { return res.ok ? res.text() : null; })
            .catch(function() { return null; });
        })
      ).then(function(results) {
        var html = results
          .filter(Boolean)
          .map(function(text) {
            var match = text.match(/<product-card[\s\S]*<\/product-card>/);
            return match ? match[0] : '';
          })
          .filter(Boolean)
          .join('');

        if (!html) return;
        track.innerHTML = html;
        section.hidden = false;
        wireArrows(mainCarousel || section, track);
      });
    } else if (fallback && fallbackTrack) {
      // State 2: No recently viewed, but fallback collection exists
      if (mainCarousel) mainCarousel.hidden = true;
      fallback.hidden = false;
      section.hidden = false;
      if (headingEl) {
        var fallbackHeading = headingEl.getAttribute('data-fallback-heading');
        if (fallbackHeading) headingEl.textContent = fallbackHeading;
      }
      wireArrows(fallback, fallbackTrack);
    }
    // State 3: No recently viewed and no fallback — stay hidden (default)
  })();
</script>

{% schema %}
{
  "name": "t:general.recently_viewed",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "RECENTLY VIEWED"
    },
    {
      "type": "collection",
      "id": "fallback_collection",
      "label": "t:labels.fallback_collection",
      "info": "t:labels.fallback_collection_info"
    },
    {
      "type": "text",
      "id": "fallback_heading",
      "label": "t:labels.fallback_heading",
      "default": "NEW ARRIVALS"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#F5F2EB"
    }
  ],
  "presets": [
    {
      "name": "t:general.recently_viewed"
    }
  ]
}
{% endschema %}
