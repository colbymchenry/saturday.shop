{% if section.blocks.size > 0 %}
  <announcement-bar
    class="announcement-bar full-width"
    style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};"
    data-interval="{{ section.settings.interval | times: 1000 }}"
    data-transition="{{ section.settings.transition_style }}"
  >
    {% for block in section.blocks %}
      <div class="announcement-bar__slide {% if forloop.first %}announcement-bar__slide--active{% endif %}" {{ block.shopify_attributes }}>
        {% if block.settings.url != blank %}
          <a href="{{ block.settings.url }}" class="announcement-bar__link">
            {{ block.settings.text }}
          </a>
        {% else %}
          <p class="announcement-bar__text">
            {{ block.settings.text }}
          </p>
        {% endif %}
      </div>
    {% endfor %}
  </announcement-bar>
{% endif %}

{% stylesheet %}
  .announcement-bar {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px var(--page-margin);
    min-height: 40px;
    overflow: hidden;
  }

  .announcement-bar__slide {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px var(--page-margin);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .announcement-bar__slide--active {
    opacity: 1;
    pointer-events: auto;
  }

  [data-transition="slide"] .announcement-bar__slide {
    opacity: 1;
    transform: translateX(100%);
    transition: transform 0.45s ease;
  }

  [data-transition="slide"] .announcement-bar__slide--active {
    transform: translateX(0);
  }

  [data-transition="slide"] .announcement-bar__slide--exit {
    transform: translateX(-100%);
  }

  .announcement-bar__link,
  .announcement-bar__text {
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    text-align: center;
  }

  .announcement-bar__link:hover {
    opacity: 0.8;
  }
{% endstylesheet %}

{% javascript %}
  class AnnouncementBar extends HTMLElement {
    connectedCallback() {
      this.slides = this.querySelectorAll('.announcement-bar__slide');
      if (this.slides.length <= 1) return;

      this.current = 0;
      this.transition = this.dataset.transition || 'fade';
      const interval = parseInt(this.dataset.interval) || 3000;
      this.timer = setInterval(() => this.next(), interval);
    }

    disconnectedCallback() {
      if (this.timer) clearInterval(this.timer);
    }

    next() {
      const outgoing = this.slides[this.current];
      this.current = (this.current + 1) % this.slides.length;
      const incoming = this.slides[this.current];

      if (this.transition === 'slide') {
        outgoing.classList.add('announcement-bar__slide--exit');
        outgoing.classList.remove('announcement-bar__slide--active');
        incoming.classList.add('announcement-bar__slide--active');
        outgoing.addEventListener('transitionend', () => {
          outgoing.classList.remove('announcement-bar__slide--exit');
        }, { once: true });
      } else {
        outgoing.classList.remove('announcement-bar__slide--active');
        incoming.classList.add('announcement-bar__slide--active');
      }
    }
  }

  if (!customElements.get('announcement-bar')) {
    customElements.define('announcement-bar', AnnouncementBar);
  }
{% endjavascript %}

{% schema %}
{
  "name": "t:general.announcement_bar",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.foreground",
      "default": "#FFFFFF"
    },
    {
      "type": "range",
      "id": "interval",
      "label": "t:labels.interval",
      "min": 1,
      "max": 10,
      "step": 1,
      "unit": "s",
      "default": 5
    },
    {
      "type": "select",
      "id": "transition_style",
      "label": "t:labels.transition",
      "default": "fade",
      "options": [
        { "value": "fade", "label": "Fade" },
        { "value": "slide", "label": "Slide" }
      ]
    }
  ],
  "blocks": [
    {
      "type": "announcement",
      "name": "t:general.announcement",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "t:labels.text",
          "default": "NEW DROP: WESTERN COLLECTION — SHOP NOW"
        },
        {
          "type": "url",
          "id": "url",
          "label": "t:labels.url"
        }
      ]
    }
  ]
}
{% endschema %}
