{% if section.settings.text != blank %}
  <div
    class="announcement-bar full-width"
    style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};"
  >
    {% if section.settings.url != blank %}
      <a href="{{ section.settings.url }}" class="announcement-bar__link">
        {{ section.settings.text }}
      </a>
    {% else %}
      <p class="announcement-bar__text">
        {{ section.settings.text }}
      </p>
    {% endif %}
  </div>
{% endif %}

{% stylesheet %}
  .announcement-bar {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 12px var(--page-margin);
  }

  .announcement-bar__link,
  .announcement-bar__text {
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: inherit;
    text-align: center;
  }

  .announcement-bar__link:hover {
    opacity: 0.8;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.announcement_bar",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "t:labels.text",
      "default": "NEW DROP: WESTERN COLLECTION — SHOP NOW"
    },
    {
      "type": "url",
      "id": "url",
      "label": "t:labels.url"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.foreground",
      "default": "#FFFFFF"
    }
  ]
}
{% endschema %}
