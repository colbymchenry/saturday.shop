  @keyframes coming-soon-pop {
    0% { opacity: 0; transform: scale(0.7); }
    100% { opacity: 1; transform: scale(1); }
  }

  @keyframes coming-soon-rise {
    0% { opacity: 0; transform: translateY(20px); }
    100% { opacity: 1; transform: translateY(0); }
  }

  /* ───── Filter sidebar / drawer ───── */
  .collection__toolbar-right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }

  .collection__filter-toggle {
    display: none;
  }

  .collection__body {
    display: grid;
    grid-template-columns: 260px 1fr;
    gap: 0 32px;
    align-items: start;
  }

  .collection__body:not(:has(.collection__sidebar)) {
    grid-template-columns: 1fr;
  }

  .collection__sidebar {
    position: sticky;
    top: 80px;
    max-height: calc(100vh - 96px);
    display: flex;
    flex-direction: column;
  }

  .collection__sidebar-form {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .collection__sidebar-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 0 16px;
    border-bottom: 1px solid var(--color-border);
  }

  .collection__sidebar-title {
    font-family: var(--font-heading--family);
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .collection__sidebar-close {
    display: none;
  }

  .collection__sidebar-body {
    flex: 1;
    overflow-y: auto;
    scrollbar-width: thin;
  }

  .collection__sidebar-footer {
    display: none;
  }

  .collection__drawer-backdrop {
    display: none;
  }

  /* ───── Filter groups (accordion) ───── */
  .filter-group {
    border-bottom: 1px solid var(--color-border);
  }

  .filter-group__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 0;
    cursor: pointer;
    list-style: none;
    user-select: none;
  }

  .filter-group__header::-webkit-details-marker {
    display: none;
  }

  .filter-group__title {
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .filter-group__chevron {
    transition: transform 0.2s ease;
  }

  .filter-group[open] .filter-group__chevron {
    transform: rotate(180deg);
  }

  .filter-group__content {
    padding: 0 0 16px;
  }

  /* ───── Filter options (checkboxes) ───── */
  .filter-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 6px 0;
    cursor: pointer;
    font-family: var(--font-body--family);
    font-size: 0.85rem;
  }

  .filter-option input[type="checkbox"] {
    position: absolute;
    opacity: 0;
    width: 0;
    height: 0;
  }

  .filter-option__checkbox {
    width: 16px;
    height: 16px;
    border: 1.5px solid var(--color-border);
    border-radius: 2px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background-color 0.15s, border-color 0.15s;
  }

  .filter-option:hover .filter-option__checkbox {
    border-color: var(--color-foreground);
  }

  .filter-option input:checked + .filter-option__checkbox {
    background: var(--color-foreground);
    border-color: var(--color-foreground);
  }

  .filter-option input:checked + .filter-option__checkbox::after {
    content: '';
    width: 8px;
    height: 5px;
    border-left: 2px solid var(--color-background);
    border-bottom: 2px solid var(--color-background);
    transform: rotate(-45deg) translateY(-1px);
  }

  .filter-option--active .filter-option__label {
    font-weight: 600;
