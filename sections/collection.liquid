  .filter-price__input-wrap input::-webkit-inner-spin-button,
  .filter-price__input-wrap input::-webkit-outer-spin-button {
    -webkit-appearance: none;
  }

  .filter-price__sep {
    font-size: 0.85rem;
    opacity: 0.4;
    padding-bottom: 10px;
  }

  /* ───── Mobile: drawer + toggle ───── */
