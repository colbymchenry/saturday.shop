{% endstylesheet %}

{% javascript %}
  class CollectionSort extends HTMLElement {
    connectedCallback() {
      this.trigger = this.querySelector('.collection__sort-trigger');
      this.trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        this.classList.toggle('collection__sort--open');
      });
      this._onDocClick = (e) => {
        if (!this.contains(e.target)) this.classList.remove('collection__sort--open');
      };
      document.addEventListener('click', this._onDocClick);
    }
    disconnectedCallback() {
      document.removeEventListener('click', this._onDocClick);
    }
  }
  if (!customElements.get('collection-sort')) {
    customElements.define('collection-sort', CollectionSort);
  }

  /* ───── Infinite scroll ───── */
  var _infiniteObserver = null;

  function initInfiniteScroll() {
    if (_infiniteObserver) {
      _infiniteObserver.disconnect();
      _infiniteObserver = null;
    }

    var sentinel = document.querySelector('[data-infinite-sentinel]');
    if (!sentinel) return;

    var grid = document.querySelector('[data-collection-grid]');
    var paginationNav = document.querySelector('[data-pagination-nav]');
    if (!grid) return;

    if (paginationNav) paginationNav.setAttribute('data-pagination-hidden', '');

    var nextUrl = sentinel.getAttribute('data-next-url');
    var currentPage = parseInt(sentinel.getAttribute('data-current-page'), 10);
    var totalPages = parseInt(sentinel.getAttribute('data-total-pages'), 10);
    var loading = false;

    if (!nextUrl || currentPage >= totalPages) {
      sentinel.hidden = true;
      return;
    }

    sentinel.hidden = false;

    _infiniteObserver = new IntersectionObserver(function (entries) {
      if (entries[0].isIntersecting && !loading && nextUrl) {
        loadNextPage();
      }
    }, { rootMargin: '200px' });

    _infiniteObserver.observe(sentinel);

    function loadNextPage() {
      loading = true;

      fetch(nextUrl)
        .then(function (res) {
          if (!res.ok) throw new Error('Failed to fetch');
          return res.text();
        })
        .then(function (html) {
          var parser = new DOMParser();
          var doc = parser.parseFromString(html, 'text/html');

          var fetchedGrid = doc.querySelector('[data-collection-grid]');
          if (fetchedGrid) {
            while (fetchedGrid.firstChild) {
              grid.appendChild(fetchedGrid.firstChild);
            }
          }

          var fetchedSentinel = doc.querySelector('[data-infinite-sentinel]');
          if (fetchedSentinel) {
            nextUrl = fetchedSentinel.getAttribute('data-next-url');
            currentPage = parseInt(fetchedSentinel.getAttribute('data-current-page'), 10);
          } else {
            nextUrl = null;
          }

          if (currentPage > 1) {
            var url = new URL(window.location);
            url.searchParams.set('page', currentPage);
            history.replaceState(null, '', url);
          }

          if (!nextUrl || currentPage >= totalPages) {
            sentinel.hidden = true;
            _infiniteObserver.disconnect();
          }

          loading = false;
        })
        .catch(function () {
          sentinel.hidden = true;
          _infiniteObserver.disconnect();
          if (paginationNav) paginationNav.removeAttribute('data-pagination-hidden');
          loading = false;
        });
    }
  }

  initInfiniteScroll();

  /* ───── Collection filters AJAX web component ───── */
  class CollectionFilters extends HTMLElement {
    connectedCallback() {
      this._abortController = null;
      this._priceDebounce = null;

      this._onPopState = this._handlePopState.bind(this);
      window.addEventListener('popstate', this._onPopState);

      this._onKeyDown = function (e) {
        if (e.key === 'Escape') this.closeDrawer();
      }.bind(this);
      document.addEventListener('keydown', this._onKeyDown);

      this.addEventListener('click', this._handleClick.bind(this));

      var form = this.querySelector('[data-collection-filters-form]');
      if (form) {
        form.addEventListener('submit', function (e) {
          e.preventDefault();
          this._submitForm(form);
        }.bind(this));

        form.addEventListener('change', function (e) {
          if (e.target.type === 'checkbox') this._submitForm(form);
        }.bind(this));

        form.addEventListener('input', function (e) {
          if (e.target.closest('.filter-price')) {
            clearTimeout(this._priceDebounce);
            this._priceDebounce = setTimeout(function () {
              this._submitForm(form);
            }.bind(this), 600);
          }
        }.bind(this));
      }

      var toggle = this.querySelector('[data-filter-toggle]');
      if (toggle) toggle.addEventListener('click', this.openDrawer.bind(this));
      var closeBtn = this.querySelector('[data-filter-close]');
      if (closeBtn) closeBtn.addEventListener('click', this.closeDrawer.bind(this));
      var backdrop = this.querySelector('[data-filter-backdrop]');
      if (backdrop) backdrop.addEventListener('click', this.closeDrawer.bind(this));
    }

    disconnectedCallback() {
      window.removeEventListener('popstate', this._onPopState);
      document.removeEventListener('keydown', this._onKeyDown);
      if (this._abortController) this._abortController.abort();
      clearTimeout(this._priceDebounce);
    }

    openDrawer() {
      var sidebar = this.querySelector('[data-filter-sidebar]');
      var backdrop = this.querySelector('[data-filter-backdrop]');
      if (sidebar) sidebar.classList.add('collection__sidebar--open');
      if (backdrop) backdrop.classList.add('collection__drawer-backdrop--visible');
      document.body.style.overflow = 'hidden';
    }

    closeDrawer() {
      var sidebar = this.querySelector('[data-filter-sidebar]');
      var backdrop = this.querySelector('[data-filter-backdrop]');
      if (sidebar) sidebar.classList.remove('collection__sidebar--open');
      if (backdrop) backdrop.classList.remove('collection__drawer-backdrop--visible');
      document.body.style.overflow = '';
    }

    _handleClick(e) {
      var chip = e.target.closest('.collection__chip');
      if (chip) {
        e.preventDefault();
        this.navigateTo(chip.href);
        return;
      }

      var clearAll = e.target.closest('.collection__clear-all');
      if (clearAll) {
        e.preventDefault();
        this.navigateTo(clearAll.href);
        return;
      }
    }

    _handlePopState() {
      this.navigateTo(window.location.href, false);
    }

    _submitForm(form) {
      var formData = new FormData(form);
      var url = new URL(form.action, window.location.origin);

      url.search = '';

      for (var pair of formData.entries()) {
        if (pair[1] !== '') url.searchParams.append(pair[0], pair[1]);
      }

      var currentUrl = new URL(window.location.href);
      var sortBy = currentUrl.searchParams.get('sort_by');
      if (sortBy) url.searchParams.set('sort_by', sortBy);

      this.closeDrawer();
      this.navigateTo(url.toString());
    }

    navigateTo(url, pushState) {
      if (pushState === undefined) pushState = true;
      if (this._abortController) this._abortController.abort();
      this._abortController = new AbortController();

      var sectionId = this.getAttribute('data-section-id');
      var grid = this.querySelector('[data-collection-grid]');
      if (!grid) return;

      grid.classList.add('collection__grid--loading');

      var fetchUrl = new URL(url, window.location.origin);
      fetchUrl.searchParams.set('section_id', sectionId);

      var self = this;

      fetch(fetchUrl.toString(), { signal: this._abortController.signal })
        .then(function (res) {
          if (!res.ok) throw new Error('Failed to fetch');
          return res.text();
        })
        .then(function (html) {
          var doc = new DOMParser().parseFromString(html, 'text/html');

          /* Replace product grid */
          var newGrid = doc.querySelector('[data-collection-grid]');
          if (newGrid) grid.innerHTML = newGrid.innerHTML;
          else grid.innerHTML = '';

          /* Replace product count */
          var newCount = doc.querySelector('[data-product-count]');
          var oldCount = self.querySelector('[data-product-count]');
          if (newCount && oldCount) oldCount.textContent = newCount.textContent;

          /* Replace active chips bar */
          var newChips = doc.querySelector('[data-active-filters]');
          var oldChips = self.querySelector('[data-active-filters]');
          if (newChips && oldChips) {
            oldChips.replaceWith(newChips);
          } else if (!newChips && oldChips) {
            oldChips.remove();
          } else if (newChips && !oldChips) {
            var body = self.querySelector('.collection__body');
            if (body) body.before(newChips);
          }

          /* Replace filter badge */
          var newBadge = doc.querySelector('[data-filter-badge]');
          var oldBadge = self.querySelector('[data-filter-badge]');
          var toggleBtn = self.querySelector('[data-filter-toggle]');
          if (newBadge && !oldBadge && toggleBtn) {
            toggleBtn.insertAdjacentHTML('beforeend', newBadge.outerHTML);
          } else if (!newBadge && oldBadge) {
            oldBadge.remove();
          }

          /* Replace sidebar body (filter counts & active states) */
          var newSidebarBody = doc.querySelector('.collection__sidebar-body');
          var oldSidebarBody = self.querySelector('.collection__sidebar-body');
          if (newSidebarBody && oldSidebarBody) {
            oldSidebarBody.innerHTML = newSidebarBody.innerHTML;
          }

          /* Replace sentinel */
          var newSentinel = doc.querySelector('[data-infinite-sentinel]');
          var oldSentinel = self.querySelector('[data-infinite-sentinel]');
          if (newSentinel && oldSentinel) oldSentinel.replaceWith(newSentinel);

          /* Replace pagination */
          var newPag = doc.querySelector('[data-pagination-nav]');
          var oldPag = self.querySelector('[data-pagination-nav]');
          if (newPag && oldPag) oldPag.replaceWith(newPag);
          else if (oldPag && !newPag) oldPag.remove();

          /* Replace category pills active state */
          var newPills = doc.querySelector('.collection__filters-scroll');
          var oldPills = self.querySelector('.collection__filters-scroll');
          if (newPills && oldPills) oldPills.innerHTML = newPills.innerHTML;

          initInfiniteScroll();
          grid.classList.remove('collection__grid--loading');

          if (pushState) {
            var pushUrl = new URL(url, window.location.origin);
            pushUrl.searchParams.delete('section_id');
            history.pushState(null, '', pushUrl.toString());
          }
        })
        .catch(function (err) {
          if (err.name === 'AbortError') return;
          grid.classList.remove('collection__grid--loading');
        });
    }
  }

  if (!customElements.get('collection-filters')) {
    customElements.define('collection-filters', CollectionFilters);
  }

  /* ───── Category pill filter (delegates AJAX to CollectionFilters) ───── */
  class CollectionFilter extends HTMLElement {
    connectedCallback() {
      this.addEventListener('click', this._onClick.bind(this));
    }

    _onClick(e) {
      var link = e.target.closest('.collection__filter-btn');
      if (!link) return;
      e.preventDefault();

      this.querySelectorAll('.collection__filter-btn').forEach(function (btn) {
        btn.classList.remove('collection__filter-btn--active');
      });
      link.classList.add('collection__filter-btn--active');

      var parent = this.closest('collection-filters');
      if (parent) {
        var targetUrl = new URL(link.href, window.location.origin);
        var currentUrl = new URL(window.location.href);
        currentUrl.searchParams.forEach(function (val, key) {
          if (key.startsWith('filter.')) targetUrl.searchParams.append(key, val);
        });
        parent.navigateTo(targetUrl.toString());
      }
    }
  }

  if (!customElements.get('collection-filter')) {
    customElements.define('collection-filter', CollectionFilter);
  }
{% endjavascript %}

