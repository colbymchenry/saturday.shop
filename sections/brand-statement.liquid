<section class="brand-statement full-width" style="background-color: {{ section.settings.background_color }};">
  <div class="brand-statement__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="brand-statement__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <div class="brand-statement__heading">{{ section.settings.heading }}</div>
    {% endif %}

    {% if section.settings.subtitle != blank %}
      <p class="brand-statement__subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}

    {% if section.settings.body != blank %}
      <p class="brand-statement__body">{{ section.settings.body }}</p>
    {% endif %}

    {% if section.settings.button_text != blank %}
      <a href="{{ section.settings.button_url }}" class="brand-statement__button">
        {{ section.settings.button_text }}
      </a>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .brand-statement {
    display: grid;
    grid-template-columns: var(--content-grid);
    padding: var(--section-padding-block) 0;
  }

  .brand-statement__inner {
    grid-column: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .brand-statement__eyebrow {
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent-gold);
    margin-bottom: 24px;
  }

  .brand-statement__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-foreground);
  }

  .brand-statement__heading em {
    font-style: italic;
    font-weight: 800;
  }

  .brand-statement__heading p {
    margin: 0;
  }

  .brand-statement__subtitle {
    font-family: var(--font-heading--family);
    font-size: clamp(1rem, 1.8vw, 1.2rem);
    font-weight: 700;
    color: var(--color-foreground);
    margin-top: 8px;
  }

  .brand-statement__body {
    font-family: var(--font-body--family);
    font-size: clamp(0.9rem, 1.3vw, 1.05rem);
    line-height: 1.6;
    color: var(--color-muted);
    margin-top: 24px;
    max-width: 540px;
  }

  .brand-statement__button {
    display: inline-block;
    margin-top: 32px;
    padding: 16px 40px;
    font-family: var(--font-heading--family);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-background);
    background-color: var(--color-foreground);
    transition: opacity 0.2s ease;
  }

  .brand-statement__button:hover {
    opacity: 0.85;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.brand_statement",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#F5F2EB"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "ROOTED IN TRADITION"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "t:labels.subtitle"
    },
    {
      "type": "richtext",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "<p>We dig into your school's history, traditions & lore to craft apparel <em>that actually means something.</em></p>"
    },
    {
      "type": "text",
      "id": "body",
      "label": "t:labels.description",
      "default": "180+ schools. Thoughtful designs you won't find anywhere else. Premium quality that lasts longer than your college years."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "t:labels.button_text",
      "default": "FIND YOUR SCHOOL"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "t:labels.button_url"
    }
  ],
  "presets": [
    {
      "name": "t:general.brand_statement"
    }
  ]
}
{% endschema %}
