{% endstylesheet %}

<script>
  class SearchPopover extends HTMLElement {
    connectedCallback() {
      this._popover = this.querySelector('.search-popover');
      this.input = this.querySelector('[data-search-input]');
      this.results = this.querySelector('[data-search-results]');
      this.toggle = this.querySelector('[data-search-toggle]');
      this.closeBtn = this.querySelector('[data-search-close]');
      this.overlay = this.querySelector('.search-popover__overlay');
      this.form = this.querySelector('.search-popover__form');
      this.viewAll = this.querySelector('[data-search-view-all]');
      this.currentQuery = '';

      this.toggle.addEventListener('click', () => this.open());
      this.closeBtn.addEventListener('click', () => this.close());
      this.overlay.addEventListener('click', () => this.close());

      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && this._popover.classList.contains('search-popover--open')) this.close();
      });

      this.input.addEventListener('input', this.debounce(() => {
        this.search(this.input.value.trim());
      }, 300));

      this.form.addEventListener('submit', (e) => {
        const q = this.input.value.trim();
        if (!q) {
          e.preventDefault();
          return;
        }
        // Form submits naturally to /search?q=...
      });
    }

    open() {
      // Remove hidden so elements are in the DOM, then force reflow
      // so the browser computes the "closed" styles before we animate open
      this._popover.hidden = false;
      this._popover.offsetHeight;
      this._popover.classList.add('search-popover--open');
      // Delay focus slightly so visibility: visible has applied
      setTimeout(() => this.input.focus(), 50);
    }

    close() {
      this._popover.classList.remove('search-popover--open');
      // Wait for the slide-out transition, then fully hide
      const onEnd = () => {
        this._popover.hidden = true;
        this._popover.removeEventListener('transitionend', onEnd);
      };
      this._popover.addEventListener('transitionend', onEnd);
      this.input.value = '';
      this.results.innerHTML = '';
      this.viewAll.hidden = true;
      this.currentQuery = '';
    }

    debounce(fn, ms) {
      let timer;
      return (...args) => {
        clearTimeout(timer);
        timer = setTimeout(() => fn.apply(this, args), ms);
      };
    }

    showSkeletons() {
      this.results.innerHTML = Array.from({ length: 4 }, () => `
        <div class="search-skeleton">
          <div class="search-skeleton__image"></div>
          <div class="search-skeleton__content">
            <div class="search-skeleton__title"></div>
            <div class="search-skeleton__price"></div>
          </div>
        </div>
      `).join('');
    }

    async search(query) {
      if (!query) {
        this.results.innerHTML = '';
        this.viewAll.hidden = true;
        this.currentQuery = '';
        return;
      }

      this.currentQuery = query;
      this.viewAll.hidden = true;
      this.showSkeletons();

      try {
        const res = await fetch(
          `/search/suggest.json?q=${encodeURIComponent(query)}&resources[type]=product&resources[limit]=6`
        );
        if (this.currentQuery !== query) return;
        if (!res.ok) throw new Error();

        const data = await res.json();
        const products = data.resources?.results?.products || [];

        if (products.length === 0) {
          this.results.innerHTML = '<div class="search-popover__no-results">No results found</div>';
          this.viewAll.hidden = true;
          return;
        }

        const items = products.map(p => {
          const img = p.image
            ? `<img src="${p.image}" alt="${this.esc(p.title)}" class="search-result-item__image" width="56" height="56" loading="lazy">`
            : '<div class="search-result-item__image"></div>';

          const price = this.money(p.price);
          const compare = p.compare_at_price_max && parseFloat(p.compare_at_price_max) > parseFloat(p.price)
            ? `<span class="search-result-item__compare-price">${this.money(p.compare_at_price_max)}</span>`
            : '';

          return `<a href="${p.url}" class="search-result-item">
            ${img}
            <div class="search-result-item__content">
              <h3 class="search-result-item__title">${this.esc(p.title)}</h3>
              <div class="search-result-item__price">${price}${compare}</div>
            </div>
          </a>`;
        }).join('');

        this.results.innerHTML = items;
        this.viewAll.href = `/search?q=${encodeURIComponent(query)}`;
        this.viewAll.hidden = false;

      } catch (err) {
        if (this.currentQuery === query) {
          this.results.innerHTML = '<div class="search-popover__no-results">Something went wrong</div>';
        }
      }
    }

    esc(str) {
      const el = document.createElement('span');
      el.textContent = str;
      return el.innerHTML;
    }

    money(price) {
      const amount = parseFloat(price);
      return `$${amount.toFixed(2)}`;
    }
  }

  if (!customElements.get('search-popover')) {
    customElements.define('search-popover', SearchPopover);
  }

  // Schools dropdown: hover + click + keyboard support
  (function() {
    const dropdown = document.querySelector('.schools-dropdown');
    const trigger = dropdown?.querySelector('.schools-dropdown__trigger');
    if (!dropdown || !trigger) return;

    function open() {
      dropdown.classList.add('schools-dropdown--open');
      trigger.setAttribute('aria-expanded', 'true');
    }

    function close() {
      dropdown.classList.remove('schools-dropdown--open');
      trigger.setAttribute('aria-expanded', 'false');
    }

    dropdown.addEventListener('mouseenter', open);
    dropdown.addEventListener('mouseleave', close);

    trigger.addEventListener('click', () => {
      if (dropdown.classList.contains('schools-dropdown--open')) {
        close();
      } else {
        open();
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && dropdown.classList.contains('schools-dropdown--open')) {
        close();
        trigger.focus();
      }
    });

    document.addEventListener('click', (e) => {
      if (!dropdown.contains(e.target)) {
        close();
      }
    });

    // Alphabet tab navigation — show 4 letters at a time
    const alphaTabs = dropdown.querySelectorAll('[data-alpha]');
    const alphaContent = dropdown.querySelector('[data-alpha-content]');
    const allGroups = alphaContent.querySelectorAll('.schools-dropdown__letter-group');
    const letters = 'abcdefghijklmnopqrstuvwxyz'.split('');

    function showLetters(startLetter) {
      const idx = letters.indexOf(startLetter);
      if (idx === -1) return;
      // Clamp so we always show 4 (e.g. "y" → show w,x,y,z)
      const start = Math.min(idx, letters.length - 4);
      const visible = letters.slice(start, start + 4);

      allGroups.forEach(g => {
        g.classList.remove('schools-dropdown__letter-group--visible', 'schools-dropdown__letter-group--primary');
      });
      alphaTabs.forEach(t => t.classList.remove('schools-dropdown__alpha-tab--active'));

      visible.forEach((l, i) => {
        const group = alphaContent.querySelector('[data-letter="' + l + '"]');
        if (group) {
          group.classList.add('schools-dropdown__letter-group--visible');
          if (l === startLetter) group.classList.add('schools-dropdown__letter-group--primary');
        }
      });

      const tab = dropdown.querySelector('[data-alpha="' + startLetter + '"]');
      if (tab) tab.classList.add('schools-dropdown__alpha-tab--active');
    }

    let alphaNavActive = false;
    let alphaNavTimer = null;

    // Activate letter nav after hovering inside dropdown for 1s
    dropdown.addEventListener('mouseenter', () => {
      alphaNavTimer = setTimeout(() => { alphaNavActive = true; }, 1000);
    });
    dropdown.addEventListener('mouseleave', () => {
      clearTimeout(alphaNavTimer);
      alphaNavActive = false;
    });

    alphaTabs.forEach(tab => {
      tab.addEventListener('mouseenter', () => {
        if (alphaNavActive) showLetters(tab.getAttribute('data-alpha'));
      });
      tab.addEventListener('click', () => {
        alphaNavActive = true;
        clearTimeout(alphaNavTimer);
        showLetters(tab.getAttribute('data-alpha'));
      });
    });

    // Show first letter on load
    showLetters('a');
  })();

  // Nav dropdowns: hover + click + keyboard
  (function() {
    const dropdowns = document.querySelectorAll('.nav-dropdown');
    if (!dropdowns.length) return;

    function openDropdown(dd) {
      // Close all others first
      dropdowns.forEach(other => {
        if (other !== dd) closeDropdown(other);
      });
      dd.classList.add('nav-dropdown--open');
      dd.querySelector('.nav-dropdown__trigger')?.setAttribute('aria-expanded', 'true');
    }

    function closeDropdown(dd) {
      dd.classList.remove('nav-dropdown--open');
      dd.querySelector('.nav-dropdown__trigger')?.setAttribute('aria-expanded', 'false');
    }

    dropdowns.forEach(dd => {
      const trigger = dd.querySelector('.nav-dropdown__trigger');

      dd.addEventListener('mouseenter', () => openDropdown(dd));
      dd.addEventListener('mouseleave', () => closeDropdown(dd));

      trigger.addEventListener('click', () => {
        if (dd.classList.contains('nav-dropdown--open')) {
          closeDropdown(dd);
        } else {
          openDropdown(dd);
        }
      });
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        dropdowns.forEach(dd => {
          if (dd.classList.contains('nav-dropdown--open')) {
            closeDropdown(dd);
            dd.querySelector('.nav-dropdown__trigger')?.focus();
          }
        });
      }
    });

    document.addEventListener('click', (e) => {
      dropdowns.forEach(dd => {
        if (!dd.contains(e.target)) closeDropdown(dd);
      });
    });
  })();

  // Sidebar megamenu: tab switching + product scroll
  (function() {
    document.querySelectorAll('.nav-dropdown--sidebar').forEach(dd => {
      const items = dd.querySelectorAll('.nav-dropdown__sidebar-item');
      const panes = dd.querySelectorAll('.nav-dropdown__preview-pane');
      if (!items.length) return;

      let hoverTimer = null;

      function activate(index) {
        items.forEach((item, i) => {
          item.classList.toggle('nav-dropdown__sidebar-item--active', i === index);
        });
        panes.forEach((pane, i) => {
          if (i === index) {
            pane.hidden = false;
            pane.classList.add('nav-dropdown__preview-pane--active');
          } else {
            pane.hidden = true;
            pane.classList.remove('nav-dropdown__preview-pane--active');
          }
        });
      }

      items.forEach((item, i) => {
        item.addEventListener('mouseenter', () => {
          clearTimeout(hoverTimer);
          hoverTimer = setTimeout(() => activate(i), 80);
        });
        item.addEventListener('click', () => {
          clearTimeout(hoverTimer);
          activate(i);
        });
      });

      // Product track scrolling
      dd.querySelectorAll('.nav-dropdown__products-arrow').forEach(btn => {
        btn.addEventListener('click', () => {
          const pane = btn.closest('.nav-dropdown__preview-pane');
          const track = pane?.querySelector('.nav-dropdown__products-track');
          const card = track?.querySelector('.product-card');
          if (!track || !card) return;
          const dir = btn.dataset.scrollDir === 'next' ? 1 : -1;
          track.scrollBy({ left: dir * card.offsetWidth, behavior: 'smooth' });
        });
      });
    });
  })();

  // Mobile drawer accordion
  (function() {
    const triggers = document.querySelectorAll('.mobile-drawer__group-trigger');
    triggers.forEach(trigger => {
      trigger.addEventListener('click', () => {
        const expanded = trigger.getAttribute('aria-expanded') === 'true';
        const children = trigger.nextElementSibling;
        if (expanded) {
          trigger.setAttribute('aria-expanded', 'false');
          children.hidden = true;
        } else {
          trigger.setAttribute('aria-expanded', 'true');
          children.hidden = false;
        }
      });
    });
  })();

  // Mobile drawer
  (function() {
    const toggle = document.querySelector('[data-menu-toggle]');
    const drawer = document.querySelector('[data-mobile-drawer]');
    const overlay = document.querySelector('[data-menu-overlay]');
    const closeBtn = document.querySelector('[data-menu-close]');
    if (!toggle || !drawer || !overlay) return;

    function openDrawer() {
      drawer.classList.add('mobile-drawer--open');
      overlay.classList.add('mobile-drawer__overlay--open');
      document.body.style.overflow = 'hidden';
    }

    function closeDrawer() {
      drawer.classList.remove('mobile-drawer--open');
      overlay.classList.remove('mobile-drawer__overlay--open');
      document.body.style.overflow = '';
    }

    toggle.addEventListener('click', openDrawer);
    overlay.addEventListener('click', closeDrawer);
    if (closeBtn) closeBtn.addEventListener('click', closeDrawer);

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && drawer.classList.contains('mobile-drawer--open')) {
        closeDrawer();
      }
    });
  })();
</script>

