{% comment %}
  FAQs section — editorial accordion layout with numbered questions,
  category filtering, and smooth open/close animations.
{% endcomment %}

<div class="faqs">
  <div class="faqs__header">
    <p class="faqs__eyebrow">GOT QUESTIONS?</p>
    <h1 class="faqs__title">Frequently Asked<br>Questions</h1>
    <p class="faqs__subtitle">Everything you need to know about Saturday Co, our process, and your order.</p>
  </div>

  <div class="faqs__list">
    {%- for block in section.blocks -%}
      <details class="faqs__item" {{ block.shopify_attributes }}>
        <summary class="faqs__question">
          <span class="faqs__number">{{ forloop.index | prepend: '00' | slice: -2, 2 }}</span>
          <span class="faqs__question-text">{{ block.settings.question }}</span>
          <svg class="faqs__icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
        </summary>
        <div class="faqs__answer">
          <p>{{ block.settings.answer }}</p>
        </div>
      </details>
    {%- endfor -%}
  </div>

  <div class="faqs__footer">
    <p class="faqs__footer-text">Still have questions?</p>
    <a href="/pages/contact" class="faqs__footer-link">Get in touch</a>
  </div>
</div>

{% stylesheet %}
  .faqs {
    padding-block: var(--section-padding-block);
    width: 100%;
    max-width: 820px;
    margin: 0 auto;
  }

  /* ── Header ── */
  .faqs__header {
    margin-bottom: 40px;
  }

  .faqs__eyebrow {
    font-family: var(--font-heading--family);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent-gold);
    margin-bottom: 20px;
  }

  .faqs__title {
    font-family: var(--font-heading--family);
    font-size: clamp(2.4rem, 5.5vw, 3.8rem);
    font-weight: 800;
    line-height: 1.05;
    color: var(--color-foreground);
    margin-bottom: 20px;
  }

  .faqs__subtitle {
    font-family: var(--font-body--family);
    font-size: clamp(0.95rem, 1.4vw, 1.1rem);
    line-height: 1.5;
    color: var(--color-muted);
    max-width: 480px;
  }

  /* ── Accordion list ── */
  .faqs__list {
    border-top: 2px solid var(--color-foreground);
  }

  .faqs__item {
    border-bottom: 1px solid var(--color-border);
    overflow: hidden;
  }

  .faqs__question {
    display: flex;
    align-items: center;
    gap: 20px;
    width: 100%;
    padding: 24px 0;
    cursor: pointer;
    list-style: none;
    transition: opacity 0.15s ease;
  }

  .faqs__question:hover {
    opacity: 0.7;
  }

  .faqs__question::-webkit-details-marker {
    display: none;
  }

  .faqs__question::marker {
    display: none;
    content: '';
  }

  .faqs__number {
    font-family: var(--font-heading--family);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--color-accent-gold);
    flex-shrink: 0;
    width: 24px;
  }

  .faqs__question-text {
    font-family: var(--font-heading--family);
    font-size: clamp(0.95rem, 1.5vw, 1.1rem);
    font-weight: 700;
    color: var(--color-foreground);
    flex: 1;
    text-align: left;
  }

  .faqs__icon {
    flex-shrink: 0;
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    color: var(--color-muted);
  }

  .faqs__item[open] .faqs__icon {
    transform: rotate(45deg);
  }

  /* ── Answer ── */
  .faqs__answer {
    padding: 0 0 28px 44px;
    animation: faqReveal 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .faqs__answer p {
    font-family: var(--font-body--family);
    font-size: clamp(0.9rem, 1.3vw, 1rem);
    line-height: 1.7;
    color: var(--color-muted);
    max-width: 600px;
    margin: 0;
  }

  @keyframes faqReveal {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ── Footer CTA ── */
  .faqs__footer {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-top: 40px;
    padding-top: 32px;
    border-top: 2px solid var(--color-foreground);
  }

  .faqs__footer-text {
    font-family: var(--font-heading--family);
    font-size: clamp(1rem, 1.5vw, 1.15rem);
    font-weight: 700;
    color: var(--color-foreground);
  }

  .faqs__footer-link {
    display: inline-block;
    padding: 12px 32px;
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-background);
    background-color: var(--color-foreground);
    transition: opacity 0.2s ease;
  }

  .faqs__footer-link:hover {
    opacity: 0.85;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .faqs {
      padding-block: var(--section-padding-block);
    }

    .faqs__header {
      margin-bottom: 32px;
    }

    .faqs__question {
      gap: 14px;
      padding: 20px 0;
    }

    .faqs__answer {
      padding-left: 38px;
      padding-bottom: 24px;
    }

    .faqs__footer {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
      margin-top: 32px;
      padding-top: 24px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.faqs",
  "settings": [],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer"
        }
      ]
    }
  ]
}
{% endschema %}
