<section class="about-narrative full-width">
  {% if section.settings.eyebrow != blank or section.settings.heading != blank %}
    <div class="about-narrative__header">
      {% if section.settings.eyebrow != blank %}
        <p class="about-narrative__section-eyebrow">{{ section.settings.eyebrow }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="about-narrative__section-heading">{{ section.settings.heading }}</h2>
      {% endif %}
    </div>
  {% endif %}

  {% for block in section.blocks %}
    <article class="about-narrative__chapter" {{ block.shopify_attributes }}>
      <div class="about-narrative__image">
        {% if block.settings.image %}
          {{ block.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy' }}
        {% else %}
          {{ 'hero-apparel-1' | placeholder_svg_tag }}
        {% endif %}
      </div>
      <div class="about-narrative__text">
        {% if block.settings.eyebrow != blank %}
          <p class="about-narrative__eyebrow">{{ block.settings.eyebrow }}</p>
        {% endif %}
        {% if block.settings.heading != blank %}
          <h3 class="about-narrative__heading">{{ block.settings.heading }}</h3>
        {% endif %}
        {% if block.settings.body != blank %}
          <p class="about-narrative__body">{{ block.settings.body }}</p>
        {% endif %}
      </div>
    </article>
  {% endfor %}
</section>

{% stylesheet %}
  .about-narrative {
    padding: 0;
  }

  .about-narrative__header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 72px;
    padding: 0 var(--page-margin);
  }

  .about-narrative__section-eyebrow {
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent-gold);
    margin-bottom: 16px;
  }

  .about-narrative__section-heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-foreground);
  }

  .about-narrative__chapter {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 520px;
  }

  .about-narrative__chapter:nth-child(odd) .about-narrative__image {
    order: 2;
  }

  .about-narrative__image {
    position: relative;
    overflow: hidden;
  }

  .about-narrative__image img,
  .about-narrative__image svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .about-narrative__text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 64px clamp(32px, 5vw, 80px);
  }

  .about-narrative__eyebrow {
    font-family: var(--font-heading--family);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent-rust);
    margin-bottom: 16px;
  }

  .about-narrative__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.4rem, 2.8vw, 2rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--color-foreground);
    margin: 0;
  }

  .about-narrative__body {
    font-family: var(--font-body--family);
    font-size: clamp(0.9rem, 1.2vw, 1.05rem);
    line-height: 1.7;
    color: var(--color-muted);
    margin-top: 20px;
  }

  @media (max-width: 900px) {
    .about-narrative {
      padding: 64px 0;
    }

    .about-narrative__header {
      margin-bottom: 48px;
    }

    .about-narrative__chapter {
      grid-template-columns: 1fr;
      min-height: auto;
    }

    .about-narrative__chapter:nth-child(odd) .about-narrative__image {
      order: 0;
    }

    .about-narrative__image {
      aspect-ratio: 3 / 2;
    }

    .about-narrative__text {
      max-width: none;
      padding: 40px clamp(20px, 5vw, 48px);
    }

    .about-narrative__chapter:nth-child(even) .about-narrative__text,
    .about-narrative__chapter:nth-child(odd) .about-narrative__text {
      margin-left: 0;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.about_narrative",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading"
    }
  ],
  "blocks": [
    {
      "type": "chapter",
      "name": "t:general.about_chapter",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "t:labels.image"
        },
        {
          "type": "text",
          "id": "eyebrow",
          "label": "t:labels.eyebrow"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "t:labels.description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.about_narrative",
      "blocks": [
        {
          "type": "chapter",
          "settings": {
            "eyebrow": "THE BEGINNING",
            "heading": "Born on game day, built for every day.",
            "body": "It started with a frustration every fan knows — walking into a campus bookstore and finding the same generic logo tees that every other school has. We knew college apparel could be so much more. So we set out to create it."
          }
        },
        {
          "type": "chapter",
          "settings": {
            "eyebrow": "THE PROCESS",
            "heading": "We do the homework so you don't have to.",
            "body": "For every school we launch, we dig deep into its history, traditions, and culture. We talk to students and alumni. We visit campuses. We learn the inside jokes, the landmarks, the fight songs — everything that makes a school feel like home."
          }
        },
        {
          "type": "chapter",
          "settings": {
            "eyebrow": "THE CRAFT",
            "heading": "Premium quality, no shortcuts.",
            "body": "Every piece is made with heavyweight 6.5 oz cotton jersey, pre-washed for a broken-in feel from day one. We obsess over fabric weight, ink quality, and construction because your school pride deserves better than a cheap screen print on a thin blank."
          }
        }
      ]
    }
  ]
}
{% endschema %}
