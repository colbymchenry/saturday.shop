<footer class="full-width footer--{{ section.settings.footer_style }}">
  {% if section.settings.logo_mark != blank %}
    <div class="footer__logo-mark">
      {{ section.settings.logo_mark | image_url: width: 240 | image_tag:
        class: 'footer__logo-mark-img',
        widths: '80, 120, 160, 240',
        sizes: '80px',
        alt: section.settings.logo_mark.alt | default: shop.name
      }}
    </div>
  {% endif %}

  <div class="footer__columns">
    {% for link in section.settings.menu.links %}
      <div class="footer__column">
        <h4 class="footer__heading">{{ link.title }}</h4>
        {% if link.links.size > 0 %}
          <ul class="footer__links">
            {% for child_link in link.links %}
              <li><a href="{{ child_link.url }}">{{ child_link.title }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    {% endfor %}

    <div class="footer__column footer__column--cta">
      <h4 class="footer__heading">{{ section.settings.cta_heading }}</h4>
      {% if section.settings.cta_body != blank %}
        <p class="footer__cta-body">{{ section.settings.cta_body }}</p>
      {% endif %}

      {% form 'customer', id: 'FooterNewsletter' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        {% if form.posted_successfully? %}
          <p class="footer__newsletter-success">Thanks for subscribing!</p>
        {% endif %}
        {% if form.errors %}
          <p class="footer__newsletter-error">{{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}</p>
        {% endif %}
        <div class="footer__newsletter-row">
          <input
            type="email"
            name="contact[email]"
            placeholder="Your email"
            required
            autocomplete="email"
            class="footer__newsletter-input"
            aria-label="Email address"
          >
          <button type="submit" class="footer__newsletter-button" aria-label="Subscribe">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          </button>
        </div>
      {% endform %}

      {% if section.settings.social_instagram != blank or section.settings.social_tiktok != blank or section.settings.social_twitter != blank %}
        <div class="footer__social">
          {% if section.settings.social_instagram != blank %}
            <a href="{{ section.settings.social_instagram }}" target="_blank" rel="noopener" aria-label="Instagram">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
            </a>
          {% endif %}
          {% if section.settings.social_tiktok != blank %}
            <a href="{{ section.settings.social_tiktok }}" target="_blank" rel="noopener" aria-label="TikTok">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 0 0-.79-.05A6.34 6.34 0 0 0 3.15 15a6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.34-6.34V9.19a8.16 8.16 0 0 0 4.76 1.52v-3.4a4.85 4.85 0 0 1-1-.62z"/></svg>
            </a>
          {% endif %}
          {% if section.settings.social_twitter != blank %}
            <a href="{{ section.settings.social_twitter }}" target="_blank" rel="noopener" aria-label="Twitter/X">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>

  <div class="footer__bottom">
    <div class="footer__copyright">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
    </div>
    <p class="footer__tagline">Wear the Tradition.</p>

    {% if section.settings.show_payment_icons %}
      <div class="footer__payment">
        {% for type in shop.enabled_payment_types %}
          {{ type | payment_type_svg_tag }}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</footer>

{% stylesheet %}
  /* Theme tokens — dark is default, overridden per variant */
  footer {
    --footer-bg: var(--color-foreground);
    --footer-text: var(--color-background);
    --footer-heading: var(--color-accent-gold);
    --footer-muted: color-mix(in srgb, var(--footer-text) 50%, transparent);
    --footer-border: color-mix(in srgb, var(--footer-text) 15%, transparent);
    --footer-input-bg: color-mix(in srgb, var(--footer-text) 8%, transparent);
    --footer-btn-bg: var(--color-accent-gold);
    --footer-btn-text: var(--color-foreground);
  }

  .footer--cream {
    --footer-bg: var(--color-cream);
    --footer-text: var(--color-foreground);
    --footer-heading: var(--color-foreground);
    --footer-muted: var(--color-muted);
    --footer-border: var(--color-border);
    --footer-input-bg: var(--color-background);
    --footer-btn-bg: var(--color-foreground);
    --footer-btn-text: var(--color-background);
  }

  .footer--light {
    --footer-bg: var(--color-background);
    --footer-text: var(--color-foreground);
    --footer-heading: var(--color-foreground);
    --footer-muted: var(--color-muted);
    --footer-border: var(--color-border);
    --footer-input-bg: transparent;
    --footer-btn-bg: var(--color-foreground);
    --footer-btn-text: var(--color-background);
  }

  footer {
    background: var(--footer-bg);
    color: var(--footer-text);
    padding: 72px var(--page-margin) 0;
    margin-top: 0;
  }

  .footer__logo-mark {
    text-align: center;
    margin-bottom: 40px;
  }

  .footer__logo-mark-img {
    max-width: 80px;
    height: auto;
  }

  .footer__columns {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 48px;
    padding-bottom: 56px;
    max-width: var(--page-width);
    margin: 0 auto;
  }

  .footer__heading {
    font-family: var(--font-heading--family);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--footer-heading);
    margin-bottom: 24px;
  }

  .footer__links {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .footer__links a {
    font-family: var(--font-body--family);
    font-size: 0.9rem;
    text-decoration: none;
    color: var(--footer-text);
    transition: opacity 0.2s ease;
  }

  .footer__links a:hover {
    opacity: 0.6;
  }

  .footer__cta-body {
    font-family: var(--font-body--family);
    font-size: 0.9rem;
    line-height: 1.6;
    color: var(--footer-text);
    margin-bottom: 20px;
  }

  .footer__newsletter-row {
    display: flex;
    gap: 0;
    margin-top: 16px;
  }

  .footer__newsletter-input {
    flex: 1;
    padding: 12px 16px;
    font-family: var(--font-body--family);
    font-size: 0.85rem;
    border: 1px solid var(--footer-border);
    border-right: none;
    border-radius: var(--style-border-radius-inputs) 0 0 var(--style-border-radius-inputs);
    background: var(--footer-input-bg);
    color: var(--footer-text);
    outline: none;
    transition: border-color 0.2s ease;
  }

  .footer__newsletter-input::placeholder {
    color: var(--footer-muted);
  }

  .footer__newsletter-input:focus {
    border-color: var(--footer-text);
  }

  .footer__newsletter-button {
    padding: 12px 16px;
    background: var(--footer-btn-bg);
    color: var(--footer-btn-text);
    border: 1px solid var(--footer-btn-bg);
    border-radius: 0 var(--style-border-radius-inputs) var(--style-border-radius-inputs) 0;
    cursor: pointer;
    transition: opacity 0.2s ease;
    display: flex;
    align-items: center;
  }

  .footer__newsletter-button:hover {
    opacity: 0.85;
  }

  .footer__newsletter-success {
    font-family: var(--font-body--family);
    font-size: 0.85rem;
    color: var(--footer-text);
    margin-bottom: 8px;
  }

  .footer__newsletter-error {
    font-family: var(--font-body--family);
    font-size: 0.85rem;
    color: #e05252;
    margin-bottom: 8px;
  }

  .footer__social {
    display: flex;
    gap: 16px;
    margin-top: 24px;
  }

  .footer__social a {
    color: var(--footer-text);
    transition: opacity 0.2s ease;
  }

  .footer__social a:hover {
    opacity: 0.6;
  }

  .footer__social svg {
    width: 20px;
    height: 20px;
  }

  .footer__bottom {
    border-top: 1px solid var(--footer-border);
    margin-left: calc(-1 * var(--page-margin));
    margin-right: calc(-1 * var(--page-margin));
    padding: 40px var(--page-margin) 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  .footer__copyright {
    font-family: var(--font-body--family);
    font-size: 0.8rem;
    color: var(--footer-muted);
  }

  .footer__tagline {
    font-family: var(--font-heading--family);
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--footer-heading);
    margin-top: 4px;
  }

  .footer__payment {
    display: flex;
    gap: 8px;
    margin-top: 12px;
    opacity: 0.5;
  }

  .footer__payment svg {
    height: 24px;
    width: auto;
  }

  @media (max-width: 768px) {
    footer {
      padding-top: 56px;
    }

    .footer__columns {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
  }

  @media (max-width: 480px) {
    .footer__columns {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "select",
      "id": "footer_style",
      "label": "Footer style",
      "options": [
        { "value": "dark", "label": "Dark" },
        { "value": "cream", "label": "Cream" },
        { "value": "light", "label": "Light" }
      ],
      "default": "dark"
    },
    {
      "type": "image_picker",
      "id": "logo_mark",
      "label": "Footer logo mark"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "t:labels.heading",
      "default": "SIGN UP AND SAVE"
    },
    {
      "type": "text",
      "id": "cta_body",
      "label": "t:labels.description",
      "default": "Subscribe to get special offers, free giveaways, and once-in-a-lifetime deals."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    },
    {
      "type": "header",
      "content": "t:labels.social_media"
    },
    {
      "type": "url",
      "id": "social_instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "social_tiktok",
      "label": "TikTok URL"
    },
    {
      "type": "url",
      "id": "social_twitter",
      "label": "Twitter/X URL"
    }
  ]
}
{% endschema %}
