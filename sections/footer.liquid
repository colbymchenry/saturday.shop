<footer class="full-width">
  <div class="footer__columns">
    {% if section.settings.menu_1.links.size > 0 %}
      <div class="footer__column">
        <h4 class="footer__heading">{{ section.settings.menu_1.title }}</h4>
        <ul class="footer__links">
          {% for link in section.settings.menu_1.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    {% if section.settings.menu_2.links.size > 0 %}
      <div class="footer__column">
        <h4 class="footer__heading">{{ section.settings.menu_2.title }}</h4>
        <ul class="footer__links">
          {% for link in section.settings.menu_2.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    {% if section.settings.menu_3.links.size > 0 %}
      <div class="footer__column">
        <h4 class="footer__heading">{{ section.settings.menu_3.title }}</h4>
        <ul class="footer__links">
          {% for link in section.settings.menu_3.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      </div>
    {% endif %}

    <div class="footer__column footer__column--cta">
      <h4 class="footer__heading">{{ section.settings.cta_heading }}</h4>
      {% if section.settings.cta_body != blank %}
        <p class="footer__cta-body">{{ section.settings.cta_body }}</p>
      {% endif %}
      {% if section.settings.cta_button_text != blank %}
        <a href="{{ section.settings.cta_button_url }}" class="footer__cta-button">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          {{ section.settings.cta_button_text }}
        </a>
      {% endif %}
    </div>
  </div>

  <div class="footer__bottom">
    <div class="footer__copyright">
      <strong>{{ shop.name }}</strong>
      <span>{{ powered_by_link }}</span>
    </div>

    {% if section.settings.show_payment_icons %}
      <div class="footer__payment">
        {% for type in shop.enabled_payment_types %}
          {{ type | payment_type_svg_tag }}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</footer>

{% stylesheet %}
  footer {
    border-top: 1px solid var(--color-border);
    padding: 48px var(--page-margin) 0;
    margin-top: 0;
  }

  .footer__columns {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
    padding-bottom: 48px;
  }

  .footer__heading {
    font-family: var(--font-heading--family);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-foreground);
    margin-bottom: 20px;
  }

  .footer__links {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer__links a {
    font-family: var(--font-body--family);
    font-size: 0.9rem;
    text-decoration: none;
    color: var(--color-foreground);
    transition: opacity 0.2s ease;
  }

  .footer__links a:hover {
    opacity: 0.6;
  }

  .footer__cta-body {
    font-family: var(--font-body--family);
    font-size: 0.9rem;
    line-height: 1.5;
    color: var(--color-foreground);
    margin-bottom: 20px;
  }

  .footer__cta-button {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 14px 28px;
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-background);
    background-color: var(--color-foreground);
    transition: opacity 0.2s ease;
  }

  .footer__cta-button:hover {
    opacity: 0.85;
  }

  .footer__bottom {
    border-top: 1px solid var(--color-border);
    margin-left: calc(-1 * var(--page-margin));
    margin-right: calc(-1 * var(--page-margin));
    padding: 32px var(--page-margin) 32px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    text-align: center;
  }

  .footer__copyright {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
  }

  .footer__copyright strong {
    font-family: var(--font-heading--family);
    font-size: 0.95rem;
    font-weight: 700;
  }

  .footer__copyright span,
  .footer__copyright a {
    font-family: var(--font-body--family);
    font-size: 0.8rem;
    color: var(--color-muted);
    text-decoration: none;
  }

  .footer__payment {
    display: flex;
    gap: 8px;
    margin-top: 8px;
  }

  .footer__payment svg {
    height: 24px;
    width: auto;
  }

  @media (max-width: 768px) {
    .footer__columns {
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
  }

  @media (max-width: 480px) {
    .footer__columns {
      grid-template-columns: 1fr;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.footer",
  "settings": [
    {
      "type": "link_list",
      "id": "menu_1",
      "label": "t:labels.menu_1"
    },
    {
      "type": "link_list",
      "id": "menu_2",
      "label": "t:labels.menu_2"
    },
    {
      "type": "link_list",
      "id": "menu_3",
      "label": "t:labels.menu_3"
    },
    {
      "type": "text",
      "id": "cta_heading",
      "label": "t:labels.heading",
      "default": "SIGN UP AND SAVE"
    },
    {
      "type": "text",
      "id": "cta_body",
      "label": "t:labels.description",
      "default": "Subscribe to get special offers, free giveaways, and once-in-a-lifetime deals."
    },
    {
      "type": "text",
      "id": "cta_button_text",
      "label": "t:labels.button_text",
      "default": "SIGN UP & SAVE"
    },
    {
      "type": "url",
      "id": "cta_button_url",
      "label": "t:labels.button_url"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "t:labels.show_payment_icons",
      "default": true
    }
  ]
}
{% endschema %}
