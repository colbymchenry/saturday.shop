<section class="about-values full-width" style="background-color: {{ section.settings.background_color }}; color: {{ section.settings.text_color }};">
  <div class="about-values__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="about-values__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="about-values__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="about-values__grid">
      {% for block in section.blocks %}
        <div class="about-values__item" {{ block.shopify_attributes }}>
          <span class="about-values__number">{% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}</span>
          <div class="about-values__divider"></div>
          <h3 class="about-values__item-heading">{{ block.settings.heading }}</h3>
          {% if block.settings.body != blank %}
            <p class="about-values__item-body">{{ block.settings.body }}</p>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .about-values {
    display: grid;
    grid-template-columns: var(--content-grid);
    padding: 100px 0;
  }

  .about-values__inner {
    grid-column: 2;
  }

  .about-values__eyebrow {
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent-gold);
    margin-bottom: 20px;
    text-align: center;
  }

  .about-values__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 800;
    line-height: 1.15;
    text-align: center;
    margin: 0 0 72px;
  }

  .about-values__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 48px;
  }

  .about-values__item {
    display: flex;
    flex-direction: column;
  }

  .about-values__number {
    font-family: var(--font-heading--family);
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    font-weight: 800;
    line-height: 1;
    color: var(--color-accent-gold);
    opacity: 0.35;
  }

  .about-values__divider {
    width: 32px;
    height: 1px;
    background-color: currentColor;
    opacity: 0.2;
    margin: 20px 0;
  }

  .about-values__item-heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }

  .about-values__item-body {
    font-family: var(--font-body--family);
    font-size: clamp(0.85rem, 1.1vw, 0.95rem);
    line-height: 1.65;
    opacity: 0.7;
    margin-top: 12px;
  }

  @media (max-width: 900px) {
    .about-values {
      padding: 72px 0;
    }

    .about-values__heading {
      margin-bottom: 48px;
    }

    .about-values__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 40px 32px;
    }
  }

  @media (max-width: 500px) {
    .about-values__grid {
      grid-template-columns: 1fr;
      gap: 36px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:general.about_values",
  "settings": [
    {
      "type": "color",
      "id": "background_color",
      "label": "t:labels.background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "t:labels.foreground",
      "default": "#FFFFFF"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "t:labels.eyebrow",
      "default": "WHAT WE BELIEVE"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "t:labels.heading",
      "default": "Built on four principles."
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "t:general.about_value",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "t:labels.heading"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "t:labels.description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "t:general.about_values",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "heading": "School-Specific Authenticity",
            "body": "Every design is rooted in real tradition — the landmarks, fight songs, and stories that make each school irreplaceable."
          }
        },
        {
          "type": "value",
          "settings": {
            "heading": "Insider Knowledge",
            "body": "Created by people who do the homework. We research each campus deeply so every detail resonates with the people who lived it."
          }
        },
        {
          "type": "value",
          "settings": {
            "heading": "Fashion Forward",
            "body": "This isn't just gameday gear. We design apparel you'll reach for on any Saturday — and every day in between."
          }
        },
        {
          "type": "value",
          "settings": {
            "heading": "Anti-Template",
            "body": "No generic logos on blanks. No cookie-cutter designs with a school name swapped in. Every product is crafted from scratch."
          }
        }
      ]
    }
  ]
}
{% endschema %}
