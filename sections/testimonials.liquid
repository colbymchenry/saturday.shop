<section class="testimonials">
  {% if section.settings.heading != blank %}
    <h2 class="testimonials__heading">{{ section.settings.heading }}</h2>
  {% endif %}

  <div class="testimonials__summary">
    <div class="testimonials__stars testimonials__stars--large">
      {% for i in (1..5) %}
        <svg width="24" height="24" viewBox="0 0 24 24" fill="var(--color-accent-gold)" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
      {% endfor %}
    </div>
    {% if section.settings.review_count != blank %}
      <p class="testimonials__count">Based on {{ section.settings.review_count }} reviews</p>
    {% endif %}
  </div>

  <review-carousel class="testimonials__carousel">
    <div class="testimonials__track">
      {% for block in section.blocks %}
        <div class="testimonial-card" {{ block.shopify_attributes }}>
          <div class="testimonials__stars">
            {% assign stars = block.settings.rating | default: 5 %}
            {% for i in (1..stars) %}
              <svg width="18" height="18" viewBox="0 0 24 24" fill="var(--color-accent-gold)" aria-hidden="true"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            {% endfor %}
          </div>

          <blockquote class="testimonial-card__quote">{{ block.settings.quote }}</blockquote>

          {% if block.settings.image %}
            <div class="testimonial-card__image">
              {{ block.settings.image | image_url: width: 300, height: 300, crop: 'center' | image_tag: loading: 'lazy' }}
            </div>
          {% endif %}

          <div class="testimonial-card__author">
            {% if block.settings.name != blank %}
              <strong class="testimonial-card__name">{{ block.settings.name }}</strong>
            {% endif %}
            {% if block.settings.school != blank %}
              <span class="testimonial-card__school">{{ block.settings.school }}</span>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>

    <div class="testimonials__dots">
      {% assign total_pages = section.blocks.size | minus: 1 | divided_by: 3 | plus: 1 %}
      {% for i in (1..total_pages) %}
        <button class="testimonials__dot {% if forloop.first %}testimonials__dot--active{% endif %}" data-page="{{ forloop.index0 }}" aria-label="Page {{ forloop.index }}"></button>
      {% endfor %}
    </div>
  </review-carousel>

  {% if section.settings.button_text != blank %}
    <div class="testimonials__cta">
      <a href="{{ section.settings.button_url }}" class="testimonials__button">
        {{ section.settings.button_text }}
      </a>
    </div>
  {% endif %}
</section>

{% stylesheet %}
  .testimonials {
    padding: 56px 0;
    text-align: center;
  }

  .testimonials__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    font-weight: 800;
    margin-bottom: 12px;
  }

  .testimonials__summary {
    margin-bottom: 32px;
  }

  .testimonials__stars {
    display: flex;
    justify-content: center;
    gap: 2px;
  }

  .testimonials__stars--large {
    margin-bottom: 4px;
  }

  .testimonials__count {
    font-family: var(--font-body--family);
    font-size: 0.85rem;
    color: var(--color-muted);
  }

  /* Carousel */
  review-carousel {
    display: block;
  }

  .testimonials__track {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -webkit-overflow-scrolling: touch;
    scroll-behavior: smooth;
    gap: 20px;
    padding: 0 var(--page-margin);
  }

  .testimonials__track::-webkit-scrollbar {
    display: none;
  }

  /* Review card */
  .testimonial-card {
    flex: 0 0 calc(33.333% - 14px);
    min-width: 280px;
    scroll-snap-align: start;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 32px 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .testimonial-card__quote {
    font-family: var(--font-body--family);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-foreground);
    margin: 16px 0 20px;
  }

  .testimonial-card__image {
    width: 180px;
    height: 180px;
    overflow: hidden;
    margin-bottom: 16px;
  }

  .testimonial-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .testimonial-card__author {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .testimonial-card__name {
    font-family: var(--font-heading--family);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .testimonial-card__school {
    font-family: var(--font-body--family);
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  /* Dots */
  .testimonials__dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 28px;
  }

  .testimonials__dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: none;
    background-color: var(--color-border);
    cursor: pointer;
    padding: 0;
    transition: background-color 0.2s ease;
  }

  .testimonials__dot--active {
    background-color: var(--color-foreground);
  }

  /* CTA */
  .testimonials__cta {
    margin-top: 28px;
  }

  .testimonials__button {
    display: inline-block;
    padding: 16px 40px;
    font-family: var(--font-heading--family);
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-background);
    background-color: var(--color-foreground);
    transition: opacity 0.2s ease;
  }

  .testimonials__button:hover {
    opacity: 0.85;
  }

  @media (max-width: 900px) {
    .testimonial-card {
      flex: 0 0 80%;
    }
  }
{% endstylesheet %}

{% javascript %}
  class ReviewCarousel extends HTMLElement {
    connectedCallback() {
      this.track = this.querySelector('.testimonials__track');
      this.dots = this.querySelectorAll('.testimonials__dot');

      this.dots.forEach(dot => {
        dot.addEventListener('click', () => {
          const page = parseInt(dot.dataset.page);
          const card = this.track.querySelector('.testimonial-card');
          if (!card) return;
          const cardWidth = card.offsetWidth + 20;
          this.track.scrollTo({ left: page * cardWidth * 3, behavior: 'smooth' });
          this.setActiveDot(page);
        });
      });

      this.track.addEventListener('scroll', () => {
        if (this.scrollTimer) clearTimeout(this.scrollTimer);
        this.scrollTimer = setTimeout(() => this.updateDots(), 100);
      });
    }

    setActiveDot(index) {
      this.dots.forEach((d, i) => d.classList.toggle('testimonials__dot--active', i === index));
    }

    updateDots() {
      const card = this.track.querySelector('.testimonial-card');
      if (!card) return;
      const cardWidth = card.offsetWidth + 20;
      const page = Math.round(this.track.scrollLeft / (cardWidth * 3));
      this.setActiveDot(page);
    }
  }

  if (!customElements.get('review-carousel')) {
    customElements.define('review-carousel', ReviewCarousel);
  }
{% endjavascript %}

