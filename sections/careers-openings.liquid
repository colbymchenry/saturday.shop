<section class="careers-openings full-width">
  <div class="careers-openings__inner">
    {% if section.settings.eyebrow != blank %}
      <p class="careers-openings__eyebrow">{{ section.settings.eyebrow }}</p>
    {% endif %}

    {% if section.settings.heading != blank %}
      <h2 class="careers-openings__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.body != blank %}
      <p class="careers-openings__body">{{ section.settings.body }}</p>
    {% endif %}

    <div class="careers-openings__list">
      {% for block in section.blocks %}
        <a
          href="{{ block.settings.url }}"
          class="careers-openings__role"
          {{ block.shopify_attributes }}
        >
          <div class="careers-openings__role-info">
            <h3 class="careers-openings__role-title">{{ block.settings.title }}</h3>
            {% if block.settings.department != blank %}
              <span class="careers-openings__role-department">{{ block.settings.department }}</span>
            {% endif %}
          </div>
          <div class="careers-openings__role-meta">
            {% if block.settings.location != blank %}
              <span class="careers-openings__role-location">{{ block.settings.location }}</span>
            {% endif %}
            {% if block.settings.type != blank %}
              <span class="careers-openings__role-type">{{ block.settings.type }}</span>
            {% endif %}
          </div>
          <span class="careers-openings__role-arrow">&rarr;</span>
        </a>
      {% endfor %}
    </div>

    {% if section.blocks.size == 0 %}
      <div class="careers-openings__empty">
        <p class="careers-openings__empty-text">{{ section.settings.empty_text }}</p>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .careers-openings {
    display: grid;
    grid-template-columns: var(--content-grid);
    padding: var(--section-padding-block) 0;
  }

  .careers-openings__inner {
    grid-column: 2;
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
  }

  .careers-openings__eyebrow {
    font-family: var(--font-heading--family);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: var(--color-accent-gold);
    margin-bottom: 20px;
    text-align: center;
  }

  .careers-openings__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.6rem, 3.5vw, 2.4rem);
    font-weight: 800;
    line-height: 1.15;
    text-align: center;
    margin: 0 0 16px;
  }

  .careers-openings__body {
    font-family: var(--font-body--family);
    font-size: clamp(0.9rem, 1.3vw, 1.05rem);
    line-height: 1.6;
    color: var(--color-muted);
    text-align: center;
    max-width: 540px;
    margin: 0 auto 56px;
  }

  .careers-openings__list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--color-border);
  }

  .careers-openings__role {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: 32px;
    padding: 28px 0;
    border-bottom: 1px solid var(--color-border);
    text-decoration: none;
    color: var(--color-foreground);
    transition: opacity 0.2s ease;
  }

  .careers-openings__role:hover {
    opacity: 0.7;
  }

  .careers-openings__role-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .careers-openings__role-title {
    font-family: var(--font-heading--family);
    font-size: clamp(1rem, 1.5vw, 1.2rem);
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
  }

  .careers-openings__role-department {
    font-family: var(--font-heading--family);
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--color-accent-rust);
  }

  .careers-openings__role-meta {
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .careers-openings__role-location,
  .careers-openings__role-type {
    font-family: var(--font-body--family);
    font-size: clamp(0.8rem, 1vw, 0.9rem);
    color: var(--color-muted);
  }

  .careers-openings__role-type {
    padding: 4px 12px;
    border: 1px solid var(--color-border);
    font-size: 0.75rem;
    letter-spacing: 0.05em;
  }

  .careers-openings__role-arrow {
    font-size: 1.2rem;
    color: var(--color-muted);
    transition: transform 0.2s ease;
  }

  .careers-openings__role:hover .careers-openings__role-arrow {
    transform: translateX(4px);
  }

  .careers-openings__empty {
    text-align: center;
    padding: 64px 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .careers-openings__empty-text {
    font-family: var(--font-body--family);
    font-size: clamp(0.9rem, 1.3vw, 1.05rem);
    line-height: 1.6;
    color: var(--color-muted);
  }

  @media (max-width: 900px) {
    .careers-openings__role {
      grid-template-columns: 1fr;
      gap: 12px;
      padding: 24px 0;
    }

    .careers-openings__role-arrow {
      display: none;
    }

    .careers-openings__role-meta {
      gap: 12px;
    }
  }
{% endstylesheet %}

