[
  {
    "name": "theme_info",
    "theme_name": "Skeleton",
    "theme_version": "0.1.0",
    "theme_author": "Shopify",
    "theme_documentation_url": "https://help.shopify.com/manual/online-store/themes",
    "theme_support_url": "https://support.shopify.com/"
  },
  {
    "name": "t:general.typography",
    "settings": [
      {
        "type": "header",
        "content": "t:general.fonts"
      },
      {
        "type": "font_picker",
        "id": "type_body_font",
        "default": "space_grotesk_n4",
        "label": "t:labels.body_font"
      },
      {
        "type": "font_picker",
        "id": "type_heading_font",
        "default": "poppins_n6",
        "label": "t:labels.heading_font"
      }
    ]
  },
  {
    "name": "t:general.layout",
    "settings": [
      {
        "type": "select",
        "id": "max_page_width",
        "label": "t:labels.page_width",
        "options": [
          {
            "value": "90rem",
            "label": "t:options.page_width.narrow"
          },
          {
            "value": "110rem",
            "label": "t:options.page_width.wide"
          }
        ],
        "default": "90rem"
      },
      {
        "type": "range",
        "id": "min_page_margin",
        "min": 10,
        "max": 100,
        "step": 1,
        "unit": "px",
        "label": "t:labels.page_margin",
        "default": 20
      },
      {
        "type": "range",
        "id": "section_vertical_padding",
        "min": 32,
        "max": 96,
        "step": 8,
        "unit": "px",
        "label": "t:labels.section_vertical_padding",
        "default": 56
      }
    ]
  },
  {
    "name": "t:general.favicon",
    "settings": [
      {
        "type": "image_picker",
        "id": "favicon",
        "label": "t:labels.favicon",
        "info": "t:labels.favicon_info"
      }
    ]
  },
  {
    "name": "t:general.colors",
    "settings": [
      {
        "type": "header",
        "content": "t:labels.neutrals"
      },
      {
        "type": "color",
        "id": "color_background",
        "default": "#FFFFFF",
        "label": "t:labels.background"
      },
      {
        "type": "color",
        "id": "color_page_background",
        "default": "#F5F2EB",
        "label": "t:labels.page_background"
      },
      {
        "type": "color",
        "id": "color_foreground",
        "default": "#000000",
        "label": "t:labels.foreground"
      },
      {
        "type": "color",
        "id": "color_cream",
        "default": "#F5F2EB",
        "label": "t:labels.warm_cream"
      },
      {
        "type": "header",
        "content": "t:labels.brand_accents"
      },
      {
        "type": "color",
        "id": "color_accent_gold",
        "default": "#FFB800",
        "label": "t:labels.accent_gold"
      },
      {
        "type": "color",
        "id": "color_accent_rust",
        "default": "#A65A3A",
        "label": "t:labels.accent_rust"
      },
      {
        "type": "header",
        "content": "t:labels.ui_tones"
      },
      {
        "type": "color",
        "id": "color_border",
        "default": "#E0E0E0",
        "label": "t:labels.border_color"
      },
      {
        "type": "color",
        "id": "color_card_border",
        "default": "#E0E0E0",
        "label": "t:labels.card_border_color"
      },
      {
        "type": "color",
        "id": "color_muted",
        "default": "#666666",
        "label": "t:labels.muted_text"
      },
      {
        "type": "header",
        "content": "t:labels.inputs"
      },
      {
        "type": "range",
        "id": "input_corner_radius",
        "min": 0,
        "max": 10,
        "step": 1,
        "unit": "px",
        "label": "t:labels.input_corner_radius",
        "default": 4
      }
    ]
  }
]
